{
  "name": "g2c",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/contract-bindings/*"
  ],
  "scripts": {
    "build:packages": "npm run build -w smart-account -w multisig-policy -w webauthn-verifier -w factory -w status-message -w @g2c/passkey-sdk -w @g2c/stellar-wallets-kit-module",
    "postinstall": "npm run build:packages",
    "test:support": "vitest run --config vitest.support.config.ts",
    "test:e2e": "playwright test --grep @fast",
    "test:e2e:cdp": "playwright test --project=chromium-cdp"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@noble/curves": "^2.2.0",
    "esbuild": "^0.27.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "protobufjs": "^7.5.6"
  }
}
