---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="G2C — Smart Accounts">
  <div class="page-header">
    <div class="brand">
      <h1>G2C</h1>
      <span class="brand-tag">Smart Accounts on Stellar</span>
    </div>
    <a href="https://github.com/theahaco/g2c" target="_blank" rel="noopener" class="github-link" title="View on GitHub">
      <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
    </a>
  </div>

  <p class="manifesto">Your passkey is your wallet. No seed phrases, no private keys &mdash; raw cryptographic ownership via WebAuthn.</p>

  <div id="error-box" class="error" style="display:none"></div>

  <section id="accounts-section" class="hidden">
    <h2>Your Accounts</h2>
    <div id="accounts-list"></div>
  </section>

  <section>
    <h2>Create New Account</h2>
    <p class="info">Deploys a passkey-secured smart account on Stellar testnet. One button. One passkey. Done.</p>
    <div class="field">
      <button id="create-btn">Create Account</button>
    </div>
    <div id="progress-info" class="progress" style="display:none"></div>
  </section>

  <section id="passkey-section" class="hidden">
    <h2>Passkey Setup Required</h2>
    <p class="info">Account address generated. Register a passkey to activate it on-chain.</p>
    <pre id="c-address-result"></pre>
    <div class="field">
      <a id="setup-link" class="button-link">Register Passkey & Deploy &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style>
  .brand {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .brand h1 {
    font-size: clamp(2rem, 6vw, 3rem);
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--color-accent), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .brand-tag {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  .page-header {
    margin-bottom: var(--space-md);
  }

  .github-link {
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    transition: all 0.15s ease;
  }

  .github-link:hover {
    background: var(--color-bg);
    color: var(--color-text);
    border-color: var(--color-border-strong);
  }

  .manifesto {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 55ch;
    margin-bottom: var(--space-sm);
  }

  .button-link {
    display: inline-block;
    font-family: var(--font-sans);
    background: var(--color-accent);
    color: #ffffff;
    border: none;
    padding: 0.625rem 1.25rem;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background 0.15s ease;
  }

  .button-link:hover {
    background: var(--color-accent-hover);
    color: #ffffff;
    text-decoration: none;
  }

  #accounts-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin: var(--space-md) 0;
  }

  .account-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: var(--space-md);
    text-decoration: none;
    color: var(--color-text);
    border-radius: var(--radius-md);
    transition: all 0.15s ease;
    box-shadow: var(--shadow-sm);
  }

  .account-row:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

