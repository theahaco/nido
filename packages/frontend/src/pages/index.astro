---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="G2C — Smart Accounts">
  <div class="page-header">
    <div class="title-block">
      <h1>G2C</h1>
      <div class="title-rule"></div>
      <div class="subtitle">Smart Accounts on Stellar</div>
    </div>
    <a href="https://github.com/theahaco/g2c" target="_blank" rel="noopener" class="github-link" title="View on GitHub">
      <svg width="24" height="24" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
    </a>
  </div>
  <div class="manifesto-block">
    <p class="manifesto">Your passkey is your wallet. No seed phrases. No private keys. Raw cryptographic ownership via WebAuthn.</p>
  </div>

  <div id="error-box" class="error" style="display:none"></div>

  <section id="accounts-section" class="hidden">
    <h2>// Your Accounts</h2>
    <div id="accounts-list"></div>
  </section>

  <section>
    <h2>// Create New Account</h2>
    <p class="info">Deploys a passkey-secured smart account on Stellar testnet. One button. One passkey. Done.</p>
    <div class="field">
      <button id="create-btn">Create Account</button>
    </div>
    <div id="progress-info" class="progress" style="display:none"></div>
  </section>

  <section id="passkey-section" class="hidden">
    <h2>// Passkey Setup Required</h2>
    <p class="info">Account address generated. Register a passkey to activate it on-chain.</p>
    <pre id="c-address-result"></pre>
    <div class="field">
      <a id="setup-link" class="button-link">Register Passkey & Deploy &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0;
  }

  .title-block {
    flex: 1;
  }

  .page-header h1 {
    margin: 0;
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.85;
    letter-spacing: -0.06em;
  }

  .title-rule {
    width: 100%;
    height: 0;
    border-top: 4px solid #000000;
    margin: 0.75rem 0;
  }

  .github-link {
    color: #000000;
    border: 4px solid #000000;
    padding: 0.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    background: #ffffff;
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .github-link:hover {
    background: #ffff00;
    color: #000000;
  }

  .subtitle {
    font-family: 'Space Mono', 'Courier New', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #000000;
  }

  .manifesto-block {
    border-bottom: 4px solid #000000;
    padding: 1.25rem 0;
    margin-bottom: 0;
  }

  .manifesto {
    font-size: 0.9rem;
    color: #000000;
    line-height: 1.6;
    font-weight: 400;
    max-width: 60ch;
  }

  .button-link {
    display: inline-block;
    font-family: 'Space Mono', 'Courier New', monospace;
    background: #ffff00;
    color: #000000;
    border: 4px solid #000000;
    padding: 1rem 2rem;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border-radius: 0;
  }

  .button-link:hover {
    background: #000000;
    color: #ffff00;
  }

  #accounts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 1rem 0;
  }

  .account-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #ffffff;
    border: 4px solid #000000;
    border-bottom: none;
    padding: 1.25rem;
    text-decoration: none;
    color: #000000;
  }

  .account-row:last-child {
    border-bottom: 4px solid #000000;
  }

  .account-row:hover {
    background: #ffff00;
  }

  .account-info {
    flex: 1;
    min-width: 0;
  }

  .account-name {
    font-family: 'Space Mono', 'Courier New', monospace;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #000000;
    text-transform: uppercase;
    line-height: 1;
  }

  .account-address {
    font-family: 'Space Mono', 'Courier New', monospace;
    font-size: 0.6rem;
    color: #555555;
    min-width: 0;
    word-break: break-all;
    margin-top: 0.35rem;
    letter-spacing: 0.02em;
  }

  .account-arrow {
    color: #000000;
    font-size: 2rem;
    font-weight: 700;
    flex-shrink: 0;
  }
</style>

<script>
  import { Keypair, Networks, rpc, xdr } from "@stellar/stellar-sdk";
  import { Client } from "factory";
  import {
    accountUrl,
    contractIdFromHostname,
    isContractId,
    nameFromHostname,
    resolveNameCached,
    stripSubdomain,
    loadAccounts,
    loadAccountName,
    loadPendingAccounts,
    savePendingAccount,
    activateAccount,
  } from "@g2c/passkey-sdk";

  const FACTORY_CONTRACT_ID = "CDDMELYHOSD6M2T53F5DUYCXDS3VVOQ72E4KZMMZP37GQWII2WRKM2CC";
  const RPC_URL = "https://soroban-testnet.stellar.org";
  const FRIENDBOT_URL = "https://friendbot.stellar.org";
  const NAME_REGISTRY_ID = "CDVVRZAVXTUQLS5LCGUP3H26RGOIUFKNE2UEJ6CAWYMBWY5LNORF6POX";

  // --- Name resolution redirect (if visiting via name subdomain) ---

  const hostname = window.location.hostname;
  const detectedName = nameFromHostname(hostname);

  if (detectedName && !isContractId(detectedName)) {
    // On a name subdomain — redirect to /account/ on the same subdomain
    // (keeps the shareable name URL intact)
    resolveNameCached(
      RPC_URL,
      NAME_REGISTRY_ID,
      detectedName,
      "Test SDF Network ; September 2015"
    ).then((resolved) => {
      if (resolved) {
        window.location.replace("/account/");
      }
    }).catch(() => {
      // Name not found — continue showing the home page
    });
  }

  const $createBtn = document.getElementById("create-btn") as HTMLButtonElement;
  const $progressInfo = document.getElementById("progress-info")!;
  const $passkeySection = document.getElementById("passkey-section")!;
  const $cAddressResult = document.getElementById("c-address-result") as HTMLPreElement;
  const $setupLink = document.getElementById("setup-link") as HTMLAnchorElement;
  const $errorBox = document.getElementById("error-box")!;
  const $accountsSection = document.getElementById("accounts-section")!;
  const $accountsList = document.getElementById("accounts-list")!;

  function showError(msg: string) {
    $errorBox.textContent = msg;
    $errorBox.style.display = "block";
  }

  function clearError() {
    $errorBox.style.display = "none";
  }

  // --- Show active accounts ---

  function addAccountRow(contractId: string) {
    const name = loadAccountName(contractId);

    const a = document.createElement("a");
    a.className = "account-row";
    // Link to name subdomain if available, otherwise contract-ID subdomain
    a.href = name
      ? accountUrl(window.location.host, name, "/account/")
      : accountUrl(window.location.host, contractId, "/account/");

    const info = document.createElement("div");
    info.className = "account-info";

    if (name) {
      const nameEl = document.createElement("div");
      nameEl.className = "account-name";
      nameEl.textContent = name;
      info.appendChild(nameEl);
    }

    const addr = document.createElement("div");
    addr.className = "account-address";
    addr.textContent = contractId;
    addr.title = contractId;
    info.appendChild(addr);

    const arrow = document.createElement("span");
    arrow.className = "account-arrow";
    arrow.textContent = "\u2192";

    a.appendChild(info);
    a.appendChild(arrow);
    $accountsList.appendChild(a);
    $accountsSection.classList.remove("hidden");
  }

  const activeAccounts = loadAccounts();
  for (const cAddress of activeAccounts) {
    addAccountRow(cAddress);
  }

  // --- Check pending accounts against chain ---

  async function checkContractExists(contractId: string): Promise<boolean> {
    try {
      const server = new rpc.Server(RPC_URL);
      await server.getContractData(contractId, xdr.ScVal.scvLedgerKeyContractInstance());
      return true;
    } catch {
      return false;
    }
  }

  (async () => {
    const pendingAccounts = loadPendingAccounts();
    for (const { contractId } of pendingAccounts) {
      if (activeAccounts.includes(contractId)) continue;
      const exists = await checkContractExists(contractId);
      if (exists) {
        activateAccount(contractId);
        addAccountRow(contractId);
      }
    }
  })();

  // --- Create new account ---

  $createBtn.addEventListener("click", async () => {
    clearError();
    $createBtn.disabled = true;
    $createBtn.textContent = "Creating...";

    try {
      $progressInfo.style.display = "block";
      $progressInfo.textContent = "Generating account...";

      const keypair = Keypair.random();
      const publicKey = keypair.publicKey();
      const secret = keypair.secret();

      $progressInfo.textContent = "Funding account on testnet...";
      const res = await fetch(`${FRIENDBOT_URL}?addr=${publicKey}`);
      if (!res.ok) throw new Error(`Funding failed: ${res.status}`);

      $progressInfo.textContent = "Predicting smart account address...";
      const client = new Client({
        contractId: FACTORY_CONTRACT_ID,
        networkPassphrase: Networks.TESTNET,
        rpcUrl: RPC_URL,
        publicKey: publicKey,
      });

      const tx = await client.get_c_address({ funder: publicKey });
      const cAddress = tx.result;

      // Save as pending
      savePendingAccount(cAddress, secret);

      $progressInfo.style.display = "none";
      $cAddressResult.textContent = cAddress;
      $setupLink.href = accountUrl(window.location.host, cAddress, `/new-account/?key=${secret}`);
      $passkeySection.classList.remove("hidden");

      $createBtn.textContent = "Create Account";
      $createBtn.disabled = false;
    } catch (err: any) {
      showError(err.message || String(err));
      $progressInfo.style.display = "none";
      $createBtn.textContent = "Create Account";
      $createBtn.disabled = false;
    }
  });
</script>
