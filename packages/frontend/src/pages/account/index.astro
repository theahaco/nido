---
// Nido reskin of the ACCOUNT / home page. Real logic is preserved verbatim
// from the original (BaseLayout) version — only the markup, copy and presentation
// are reskinned to the Nido "Warm Nest" design system.
//
// Layouts: NidoLayout (NOT BaseLayout). Toast + PasskeySheet are mounted once
// here so toast() and withPasskeySheet() work.
//
// Preserved logic (rewired, not rewritten):
//   - initAccountCard / fetchXlmBalance — REAL XLM balance (no fabricated USD).
//   - copy-address — now uses toast() for "Copied!" feedback.
//   - name section — saveAccountName/loadAccountName + claim/sign-redirect-return flow.
//   - passkey-info section, register section, sign-a-hash section.
//   - signing mode — reskinned with PasskeySheet + withPasskeySheet(realCeremony);
//     loadCredential / signHash / registerPasskey plumbing intact.
//
// Send & Activity from the prototype are intentionally OMITTED (no backend).
// "Settings" links out to the existing /security/ page (no settings built here).
import NidoLayout from "../../layouts/NidoLayout.astro";
import Toast from "../../components/Toast.astro";
import PasskeySheet from "../../components/PasskeySheet.astro";
import Avatar from "../../components/Avatar.astro";
import Icon from "../../components/Icon.astro";
import Qr from "../../components/Qr.astro";
import Logo from "../../components/Logo.astro";
import Nest from "../../components/Nest.astro";
---

<NidoLayout title="Your Nido">
  <div class="col-scroll scroll-hide">
    <!-- top bar -->
    <div class="topbar">
      <a id="home-link" href="/" class="topbar-mark" aria-label="Nido home"><Nest size={30} /></a>
      <a href="/account/" class="topbar-account">
        <span id="account-nickname" style="font-weight:800; font-size:14.5px; white-space:nowrap;">Your Nido</span>
        <Avatar seed="nido" size={32} class="js-avatar" />
      </a>
    </div>

    <div id="error-box" class="alert danger" style="display:none; margin:8px 22px;"></div>

    <!-- ============================================================= -->
    <!-- SIGNING MODE — reskinned signature request                    -->
    <!-- ============================================================= -->
    <div id="signing-mode" class="hidden screen-in pad" style="padding-top:18px;">
      <div style="text-align:center; margin-bottom:18px;">
        <div style="width:72px; height:72px; border-radius:20px; background:var(--acc-soft); display:grid; place-items:center; margin:0 auto 14px;">
          <Icon name="shieldcheck" size={36} color="var(--acc)" />
        </div>
        <div class="disp" style="font-weight:800; font-size:26px;">Approve this request</div>
        <p class="mut" style="font-size:14px; line-height:1.5; max-width:320px; margin:8px auto 0;">
          A dApp is asking you to sign. Review it, then confirm with your passkey.
        </p>
      </div>

      <div class="card" style="padding:4px 16px;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:14px; padding:14px 0;">
          <span class="mut" style="font-size:13.5px; font-weight:600; white-space:nowrap;">From</span>
          <span id="sign-origin" class="mono" style="font-size:13px; margin-left:auto; text-align:right; word-break:break-all;"></span>
        </div>
        <div style="display:flex; justify-content:space-between; gap:14px; padding:14px 0; border-top:1px solid var(--line-soft);">
          <span class="mut" style="font-size:13.5px; font-weight:600; white-space:nowrap;">Hash</span>
          <code id="sign-hash" class="mono" style="font-size:11.5px; margin-left:auto; text-align:right; word-break:break-all;"></code>
        </div>
      </div>

      <div id="sign-needs-register" style="margin-top:18px;">
        <p class="mut" style="font-size:13.5px; line-height:1.5; text-align:center; margin:0 0 14px;">
          You don't have a passkey on this Nido yet. Set one up first, then you can approve.
        </p>
        <button id="sign-register-btn" class="btn acc">
          <Icon name="key" size={20} color="#fff" /> Set up your passkey
        </button>
      </div>

      <div id="sign-ready" class="hidden" style="margin-top:18px;">
        <button id="approve-btn" class="btn acc">
          <Icon name="faceid" size={20} color="#fff" /> <span class="js-confirm-label">Confirm it's you</span>
        </button>
        <button id="deny-btn" class="btn ghost" style="margin-top:10px;">Not now</button>
      </div>

      <pre id="sign-mode-result" class="mono" style="display:none; margin-top:16px; font-size:12.5px; color:var(--good); text-align:center;"></pre>
    </div>

    <!-- ============================================================= -->
    <!-- HOME MODE                                                     -->
    <!-- ============================================================= -->
    <div id="home-mode" class="hidden screen-in">
      <div class="card-grid">
      <!-- balance — primary hero card, spans full width -->
      <div class="span-all" style="padding:14px 22px 0; text-align:center;">
        <div class="mut" style="font-size:13px; font-weight:700;">Balance</div>
        <div class="disp" id="xlm-balance" style="font-weight:800; font-size:48px; letter-spacing:-.01em; line-height:1.04; margin-top:4px;">…</div>
        <div class="mut" style="font-size:14px; font-weight:600; margin-top:2px;">In your Nido</div>
        <div style="display:flex; justify-content:center; margin-top:14px;">
          <button id="copy-btn" class="addr" title="Copy your address">
            <code id="contract-id" style="background:none; padding:0;"></code>
            <Icon name="copy" size={15} color="var(--ink-soft)" />
          </button>
        </div>
        <div style="margin-top:10px;">
          <a id="explorer-link" class="link" target="_blank" rel="noopener" style="display:none; font-size:13px;">View on Stellar Expert</a>
        </div>
      </div>

      <!-- quick actions — Receive (the everyday action) gets the coral emphasis
           (H-02); "Prove" is demoted to neutral + renamed the concrete job it
           does, "Approve" (→ the focused /sign/ surface); "Settings" → "Security"
           with the shield glyph so the entry points agree on one label (K-03). -->
      <div class="span-all" style="display:flex; gap:6px; padding:26px 30px 6px;">
        <button id="send-action" class="qa" type="button">
          <div class="circ"><Icon name="send" size={24} color="#fff" /></div>
          <span>Send</span>
        </button>
        <button id="receive-action" class="qa" type="button">
          <div class="circ soft"><Icon name="receive" size={23} /></div>
          <span>Receive</span>
        </button>
        <a class="qa" href="/sign/">
          <div class="circ soft"><Icon name="shieldcheck" size={23} /></div>
          <span>Approve</span>
        </a>
        <a class="qa" href="/security/">
          <div class="circ soft"><Icon name="shield" size={23} /></div>
          <span>Security</span>
        </a>
      </div>

      <!-- ============ SEND PANEL ============ -->
      <div class="grid-cell">
      <section id="send-section" class="hidden pad" style="padding-top:18px;">
        <span class="section-label" style="display:block; margin-bottom:12px;">Send XLM</span>
        <p class="mut" style="font-size:14px; line-height:1.5; margin:0 0 16px;">
          Send XLM from your Nido to any Stellar address.
        </p>
        <div class="field">
          <label for="send-to">To</label>
          <input id="send-to" class="input" placeholder="name, C…, or G…" autocomplete="off" spellcheck="false" />
          <div id="send-resolve" class="mut mono" style="font-size:12px; margin-top:6px; min-height:16px;"></div>
        </div>
        <div class="field" style="margin-top:12px;">
          <label for="send-amount">Amount</label>
          <input id="send-amount" class="input" inputmode="decimal" placeholder="0.0" />
          <div style="display:flex; justify-content:space-between; align-items:center; margin-top:6px;">
            <span id="send-balance-hint" class="mut" style="font-size:12px;"></span>
            <button id="send-max" type="button" class="link" style="font-size:12px; background:none; border:none; cursor:pointer; padding:0;">Max</button>
          </div>
        </div>
        <button id="send-submit" class="btn acc" style="margin-top:14px;">
          <Icon name="send" size={18} color="#fff" /> Send
        </button>
        <div id="send-result" class="mut mono" style="display:none; font-size:12.5px; margin-top:12px; text-align:center; line-height:1.5;"></div>
      </section>
      </div>

      <!-- ============ RECEIVE PANEL (display-only) ============ -->
      <div class="grid-cell">
      <section id="receive-section" class="hidden pad" style="text-align:center; padding-top:18px;">
        <span class="section-label" style="display:block; text-align:left; margin-bottom:12px;">Receive</span>
        <p class="mut" style="font-size:14px; line-height:1.5; max-width:320px; margin:0 auto 18px;">
          Share your address or code so anyone can send to your Nido.
        </p>
        <div style="background:var(--paper-2); border:1px solid var(--line); border-radius:22px; padding:18px; display:inline-block; box-shadow:var(--sh-1);">
          <Qr data="nido" size={188} />
        </div>
        <div class="card" style="padding:16px; margin-top:22px; text-align:left; display:flex; align-items:center; gap:12px;">
          <Avatar seed="nido" size={34} class="js-avatar" />
          <div style="flex:1; min-width:0;">
            <div style="font-weight:700; font-size:13.5px;">Your Nido</div>
            <code id="receive-address" class="mut mono" style="font-size:12px; display:block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"></code>
          </div>
        </div>
        <button id="receive-copy-btn" class="btn soft" style="margin-top:14px;">
          <Icon name="copy" size={18} /> Copy address
        </button>
      </section>
      </div>

      <!-- ============ NAME SECTION ============ -->
      <div class="grid-cell">
      <section id="name-section" class="hidden pad" style="padding-top:18px;">
        <span class="section-label" style="display:block; margin-bottom:12px;">Your name</span>

        <div id="name-display" class="hidden">
          <div class="card" style="padding:4px 16px;">
            <div style="display:flex; justify-content:space-between; align-items:center; gap:14px; padding:14px 0;">
              <span class="mut" style="font-size:13.5px; font-weight:600;">Name</span>
              <code id="account-name" class="mono" style="font-size:14px; margin-left:auto;"></code>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center; gap:14px; padding:14px 0; border-top:1px solid var(--line-soft);">
              <span class="mut" style="font-size:13.5px; font-weight:600;">Share link</span>
              <a id="name-url" class="link mono" style="font-size:12.5px; margin-left:auto; text-align:right; word-break:break-all;"></a>
            </div>
          </div>
        </div>

        <div id="name-claim" class="hidden">
          <p class="mut" style="font-size:13.5px; line-height:1.5; margin:0 0 14px;">
            Claim a friendly name for your Nido. 1–15 characters, lowercase letters and digits, starting with a letter.
          </p>
          <div class="field">
            <label for="name-input">Name</label>
            <input id="name-input" class="input" placeholder="e.g. alice" maxlength="15" pattern="[a-z][a-z0-9]*" />
          </div>
          <button id="claim-name-btn" class="btn acc" style="margin-top:12px;">Claim this name</button>
          <div id="name-result" class="mut mono" style="display:none; font-size:12.5px; margin-top:12px; text-align:center; line-height:1.5;"></div>
        </div>
      </section>
      </div>

      <!-- ============ REGISTER (when no passkey) ============ -->
      <div class="grid-cell">
      <section id="register-section" class="hidden pad" style="padding-top:18px;">
        <span class="section-label" style="display:block; margin-bottom:12px;">Set up your passkey</span>
        <div class="card" style="padding:16px;">
          <p class="mut" style="font-size:13.5px; line-height:1.5; margin:0 0 14px;">
            Create a passkey bound to this Nido. It's how you'll prove it's you — no seed phrase, no password.
          </p>
          <button id="register-btn" class="btn acc">
            <Icon name="key" size={20} color="#fff" /> Set up your passkey
          </button>
        </div>
      </section>
      </div>

      <!-- H-03: the "Developer" disclosure (status-message demo + sign-a-hash tool)
           has been removed from the consumer wallet — it belongs behind a dev flag,
           not on the primary account screen, so consumers never meet raw hashes.
           The status-message entry point will return as a link to a properly
           external dApp (tracked separately). -->

      <div class="span-all" style="display:flex; justify-content:center; margin:8px 0 28px;">
        <Logo size={18} mark markSize={24} />
      </div>
      </div>
    </div>
  </div>

  <Toast />
  <PasskeySheet />
</NidoLayout>

<script>
  import {
    Networks,
    Address,
    TransactionBuilder,
    Transaction,
    Account,
    Operation,
    Keypair,
    rpc,
    xdr,
    nativeToScVal,
  } from "@stellar/stellar-sdk";
  import {
    parseRegistration,
    derToCompact,
    buildAuthHash,
    computeAuthDigest,
    getAuthEntry,
    injectPasskeySignature,
    buf2hex,
    hex2buf,
    contractIdFromHostname,
    isContractId,
    nameFromHostname,
    resolveNameCached,
    stripSubdomain,
    accountUrl,
    saveCredential as sdkSaveCredential,
    loadCredential as sdkLoadCredential,
    saveAccountName,
    loadAccountName,
    fetchRegistryAddress,
    resolveName,
    lookupName,
  } from "@g2c/passkey-sdk";
  import { fetchVerifierAddress } from "../../lib/policyChainFetch";
  import { toast } from "../../lib/toast";
  import { withPasskeySheet } from "../../lib/passkeySheet";
  import { detectPasskeyLabel } from "../../lib/passkeyLabel";
  import { shortAddr } from "../../lib/address";
  import { formatXlm, xlmToStroops } from "../../lib/money";
  import { fetchXlmBalance } from "../../lib/balance";
  import { sendXlm } from "../../lib/sendXlm";
  import { resolveSendRecipient } from "../../lib/recipientInput";
  import { checkPasskeySupport } from "../../lib/passkeySupport";

  const RPC_URL = "https://soroban-testnet.stellar.org";

  // The on-page "Your name" / "Claim a name" card. Was parked while the claim
  // round-trip was broken (bug #3); re-enabled now that the finalize flow signs
  // and submits correctly. (Name-subdomain *resolution* below is independent of
  // this flag and stays active.)
  const SHOW_NAME_SECTION = true;

  // Friendly platform label for confirm copy ("Confirm with Face ID", etc.).
  const passkey = detectPasskeyLabel();
  const confirmLabel = `Confirm with ${passkey.label}`;
  document.querySelectorAll<HTMLElement>(".js-confirm-label").forEach((el) => {
    el.textContent = confirmLabel;
  });

  // --- URL params (needed early for signing mode detection) ---

  const params = new URLSearchParams(window.location.search);
  const signHashParam = params.get("sign");
  const callbackUrl = params.get("callback");
  const isSigningMode = signHashParam && callbackUrl;

  // --- State ---

  const hostname = window.location.hostname;
  let contractId = contractIdFromHostname(hostname);
  const rpId = hostname;

  // Cached XLM balance (string), kept fresh for the Send panel's hint, Max
  // button, and over-balance guard. Set when the balance fetch resolves.
  let currentBalanceXlm = "0";

  // Point the home link at the apex as early as possible, before any code
  // that could throw. The static fallback is href="/", but on a contract
  // subdomain the root page redirects straight back here — so if a later
  // runtime error skipped this, the home button would loop. Setting it here
  // (independent of contractId resolution) keeps it safe.
  {
    const $homeLinkEarly = document.getElementById("home-link") as HTMLAnchorElement | null;
    if ($homeLinkEarly) {
      $homeLinkEarly.href = `//${stripSubdomain(window.location.host)}/`;
    }
  }

  // --- Name resolution ---
  // If the subdomain is a human-readable name (not a 56-char contract ID),
  // resolve it to a contract ID. Stay on the name subdomain for shareability.
  // Only redirect to contract-ID subdomain when signing (passkey RP ID binding).

  const detectedName = nameFromHostname(hostname);
  if (detectedName && !isContractId(detectedName)) {
    try {
      const resolved = await resolveNameCached(
        RPC_URL,
        await fetchRegistryAddress("name-registry"),
        detectedName,
        "Test SDF Network ; September 2015"
      );
      if (resolved) {
        if (isSigningMode) {
          // Redirect to contract-ID subdomain for passkey auth
          const rootHost = stripSubdomain(window.location.host);
          const target = accountUrl(rootHost, resolved, window.location.pathname + window.location.search);
          window.location.replace(window.location.protocol + target);
          throw new Error("redirecting");
        }
        // Stay on name subdomain — use resolved ID for all operations
        contractId = resolved;
      } else {
        showError(`Name "${detectedName}" not found in the registry.`);
      }
    } catch (err: any) {
      if (err.message === "redirecting") throw err;
      showError(`Couldn't resolve that name: ${err.message}`);
    }
  }

  function saveCredential(credentialId: Uint8Array, publicKey: Uint8Array) {
    sdkSaveCredential(contractId!, credentialId, publicKey);
  }

  function loadCredential() {
    return contractId ? sdkLoadCredential(contractId) : null;
  }

  // --- Shared: register passkey ---

  async function registerPasskey() {
    if (!contractId) throw new Error("Navigate to <contractId>.<domain> to use");

    const userId = new Uint8Array(16);
    crypto.getRandomValues(userId);

    const credential = (await navigator.credentials.create({
      publicKey: {
        challenge: crypto.getRandomValues(new Uint8Array(32)),
        rp: { name: `Soroban ${contractId}`, id: rpId },
        user: {
          id: userId,
          name: contractId,
          displayName: `Account ${contractId}`,
        },
        pubKeyCredParams: [{ alg: -7, type: "public-key" }],
        authenticatorSelection: {
          residentKey: "required",
          userVerification: "required",
        },
        attestation: "none",
        timeout: 60000,
      },
    })) as PublicKeyCredential;

    const reg = parseRegistration(credential as any);
    saveCredential(reg.credentialId, reg.publicKey);
    return reg;
  }

  // --- Shared: sign hash ---

  async function signHash(hashHex: string) {
    const cred = loadCredential();
    if (!cred) throw new Error("No passkey registered");

    const challenge = hex2buf(hashHex);

    const assertion = (await navigator.credentials.get({
      publicKey: {
        challenge: challenge,
        rpId: rpId,
        allowCredentials: [
          {
            id: cred.credentialId,
            type: "public-key",
          },
        ],
        userVerification: "required",
        timeout: 60000,
      },
    })) as PublicKeyCredential;

    const response = assertion.response as AuthenticatorAssertionResponse;
    const authenticatorData = new Uint8Array(response.authenticatorData);
    const clientDataJSON = new Uint8Array(response.clientDataJSON);
    const signatureDer = new Uint8Array(response.signature);
    const signatureCompact = derToCompact(signatureDer);

    return {
      authenticatorData: buf2hex(authenticatorData),
      clientDataJSON: buf2hex(clientDataJSON),
      signature: buf2hex(signatureCompact),
      publicKey: cred.publicKey,
    };
  }

  // --- UI helpers ---

  function showError(msg: string) {
    const $errorBox = document.getElementById("error-box")!;
    $errorBox.textContent = msg;
    $errorBox.style.display = "block";
  }

  function clearError() {
    document.getElementById("error-box")!.style.display = "none";
  }

  function passkeyBlockedHint(action: "registration" | "signing"): string {
    return `Passkey ${action} was blocked. If you're using an in-app browser (Twitter, Instagram, etc.), tap the menu (…) and choose "Open in Safari" or "Open in Browser".`;
  }

  function initAccountCard() {
    const display = contractId ? shortAddr(contractId, 6, 6) : "(unknown)";
    document.getElementById("contract-id")!.textContent = display;

    const $explorerLink = document.getElementById("explorer-link") as HTMLAnchorElement;
    if (contractId) {
      $explorerLink.href = `https://stellar.expert/explorer/testnet/contract/${contractId}`;
      $explorerLink.style.display = "inline";
    }

    // Copy button — uses the Nido toast for feedback.
    document.getElementById("copy-btn")!.addEventListener("click", async () => {
      if (!contractId) return;
      try {
        await navigator.clipboard.writeText(contractId);
        toast({ msg: "Copied your address", icon: "check" });
      } catch {
        toast("Couldn't copy — try selecting it manually");
      }
    });
  }

  // =====================
  // SIGNING MODE
  // =====================

  function initSigningMode() {
    document.getElementById("signing-mode")!.classList.remove("hidden");

    // K-04: an "approve a request" moment is a single focused decision — strip
    // the wallet sidebar + topbar so this surface matches the dedicated /sign/
    // treatment, regardless of which route the request arrived on. Inline
    // display:none beats the ≥1024 sidebar media query.
    const $sidebar = document.querySelector<HTMLElement>(".nido-sidebar");
    if ($sidebar) $sidebar.style.display = "none";
    const $topbar = document.querySelector<HTMLElement>(".col-app .topbar");
    if ($topbar) $topbar.style.display = "none";

    // Show request details
    let originDisplay: string;
    try {
      originDisplay = new URL(callbackUrl!).origin;
    } catch {
      originDisplay = callbackUrl!;
    }
    document.getElementById("sign-origin")!.textContent = originDisplay;
    document.getElementById("sign-hash")!.textContent = signHashParam;

    const cred = loadCredential();
    if (cred) {
      document.getElementById("sign-ready")!.classList.remove("hidden");
      document.getElementById("sign-needs-register")!.classList.add("hidden");
    } else {
      document.getElementById("sign-needs-register")!.classList.remove("hidden");
      document.getElementById("sign-ready")!.classList.add("hidden");
    }

    // Register button in signing mode
    document.getElementById("sign-register-btn")!.addEventListener("click", async () => {
      clearError();
      const btn = document.getElementById("sign-register-btn") as HTMLButtonElement;
      const support = checkPasskeySupport();
      if (!support.ok) {
        showError(support.message!);
        return;
      }
      try {
        btn.disabled = true;
        await withPasskeySheet(() => registerPasskey(), {
          title: "Set up your passkey",
          sub: `Confirm with ${passkey.label} to create it.`,
        });
        document.getElementById("sign-needs-register")!.classList.add("hidden");
        document.getElementById("sign-ready")!.classList.remove("hidden");
      } catch (err: any) {
        if (err.name === "NotAllowedError") {
          showError(passkeyBlockedHint("registration"));
        } else {
          showError(`Couldn't set up your passkey: ${err.message}`);
        }
      } finally {
        btn.disabled = false;
      }
    });

    // Approve button
    document.getElementById("approve-btn")!.addEventListener("click", async () => {
      clearError();

      const btn = document.getElementById("approve-btn") as HTMLButtonElement;
      const support = checkPasskeySupport();
      if (!support.ok) {
        showError(support.message!);
        return;
      }
      try {
        btn.disabled = true;

        const result = await withPasskeySheet(() => signHash(signHashParam!), {
          title: confirmLabel,
          sub: "Approving the request from the app.",
        });

        const $result = document.getElementById("sign-mode-result")!;
        $result.style.display = "block";
        $result.textContent = "Approved — sending you back…";

        const cbUrl = new URL(callbackUrl!);
        cbUrl.searchParams.set("authenticatorData", result.authenticatorData);
        cbUrl.searchParams.set("clientDataJSON", result.clientDataJSON);
        cbUrl.searchParams.set("signature", result.signature);
        cbUrl.searchParams.set("publicKey", result.publicKey);

        setTimeout(() => {
          window.location.href = cbUrl.toString();
        }, 500);
      } catch (err: any) {
        if (err.name === "NotAllowedError") {
          showError(passkeyBlockedHint("signing"));
        } else {
          showError(`Couldn't confirm: ${err.message}`);
        }
        btn.disabled = false;
      }
    });

    // Deny button
    document.getElementById("deny-btn")!.addEventListener("click", () => {
      try {
        const cbUrl = new URL(callbackUrl!);
        cbUrl.searchParams.set("error", "denied");
        window.location.href = cbUrl.toString();
      } catch {
        window.history.back();
      }
    });
  }

  // =====================
  // HOME MODE
  // =====================

  function initHomeMode() {
    document.getElementById("home-mode")!.classList.remove("hidden");

    const cred = loadCredential();
    if (!cred) {
      document.getElementById("register-section")!.classList.remove("hidden");
    }

    // Receive panel toggle (display-only)
    const $receiveSection = document.getElementById("receive-section")!;
    document.getElementById("receive-action")!.addEventListener("click", () => {
      const open = $receiveSection.classList.toggle("hidden");
      if (!open) {
        $receiveSection.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
    });
    // Receive copy button
    document.getElementById("receive-copy-btn")!.addEventListener("click", async () => {
      if (!contractId) return;
      try {
        await navigator.clipboard.writeText(contractId);
        toast({ msg: "Copied your address", icon: "check" });
      } catch {
        toast("Couldn't copy — try selecting it manually");
      }
    });

    // --- Send panel ---
    const $sendSection = document.getElementById("send-section")!;
    document.getElementById("send-action")!.addEventListener("click", () => {
      const open = $sendSection.classList.toggle("hidden");
      if (!open) {
        $sendSection.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
    });

    const $sendTo = document.getElementById("send-to") as HTMLInputElement;
    const $sendAmount = document.getElementById("send-amount") as HTMLInputElement;
    const $sendResult = document.getElementById("send-result")!;
    const $sendSubmit = document.getElementById("send-submit") as HTMLButtonElement;

    const NAME_NETWORK = "Test SDF Network ; September 2015";
    let _nameRegistryIdPromise: Promise<string> | null = null;
    function nameRegistryId(): Promise<string> {
      return (_nameRegistryIdPromise ??= fetchRegistryAddress("name-registry"));
    }
    // Always resolve FRESH (no cache) so a just-transferred name can't bind stale.
    const resolveNameFresh = async (name: string): Promise<string | null> =>
      resolveName(RPC_URL, await nameRegistryId(), name, NAME_NETWORK);

    const $sendResolve = document.getElementById("send-resolve")!;
    let resolveSeq = 0;
    let resolveTimer: ReturnType<typeof setTimeout> | undefined;

    $sendTo.addEventListener("input", () => {
      clearTimeout(resolveTimer);
      const raw = $sendTo.value;
      if (!raw.trim()) {
        resolveSeq++;            // invalidate any in-flight debounced resolve
        $sendResolve.textContent = "";
        return;
      }
      $sendResolve.textContent = "Resolving…";
      resolveTimer = setTimeout(async () => {
        const myId = ++resolveSeq;
        try {
          const res = await resolveSendRecipient(raw, { resolveName: resolveNameFresh });
          if (myId !== resolveSeq) return; // a newer keystroke superseded us
          if (!res) {
            $sendResolve.textContent = "✗ No nido by that name (or invalid address)";
            return;
          }
          if (res.kind === "name") {
            $sendResolve.textContent = `✓ ${res.input} → ${shortAddr(res.address)}`;
          } else {
            let name: string | null = null;
            try {
              name = await lookupName(RPC_URL, await nameRegistryId(), res.address, NAME_NETWORK);
            } catch { /* reverse name is best-effort */ }
            if (myId !== resolveSeq) return;
            $sendResolve.textContent = name
              ? `✓ ${shortAddr(res.address)} (${name})`
              : `✓ ${shortAddr(res.address)}`;
          }
        } catch {
          if (myId === resolveSeq) $sendResolve.textContent = "✗ Couldn't resolve — try again";
        }
      }, 350);
    });

    document.getElementById("send-max")!.addEventListener("click", () => {
      $sendAmount.value = currentBalanceXlm;
    });

    $sendSubmit.addEventListener("click", async () => {
      clearError();
      if (!contractId) return;

      const to = $sendTo.value.trim();
      const amount = $sendAmount.value.trim();

      let stroops: bigint;
      try {
        stroops = xlmToStroops(amount);
      } catch {
        showError("Enter a valid amount (up to 7 decimal places).");
        return;
      }
      if (stroops <= 0n) {
        showError("Amount must be greater than zero.");
        return;
      }
      // Soft balance guard — only when we have a parseable known balance.
      try {
        if (xlmToStroops(currentBalanceXlm) < stroops) {
          showError("Amount is more than your balance.");
          return;
        }
      } catch {
        /* balance unknown/unavailable — let the network decide */
      }

      const support = checkPasskeySupport();
      if (!support.ok) {
        showError(support.message!);
        return;
      }

      try {
        $sendSubmit.disabled = true;
        $sendResult.style.display = "block";
        $sendResult.textContent = "Resolving recipient…";

        // Resolve FRESH at submit; sign over the concrete address (TOCTOU-safe).
        const resolved = await resolveSendRecipient(to, { resolveName: resolveNameFresh });
        if (!resolved) {
          showError("Enter a valid nido name, C… or G… address.");
          $sendResult.style.display = "none";
          return;
        }
        const destination = resolved.address;
        const toLabel = resolved.kind === "name" ? `${resolved.input} (${shortAddr(destination)})` : shortAddr(destination);

        $sendResult.textContent = `Confirm with ${passkey.label} to send ${amount} XLM to ${toLabel}…`;

        await sendXlm({ smartAccount: contractId, destination, stroops });

        toast({ msg: "Sent", icon: "check" });
        $sendResult.textContent = "Sent — updating your balance…";
        $sendTo.value = "";
        $sendResolve.textContent = "";
        $sendAmount.value = "";

        const fresh = await fetchXlmBalance(contractId);
        currentBalanceXlm = fresh;
        const friendly = formatXlm(fresh);
        $balance.innerHTML = `${friendly} <span class="mut" style="font-size:24px;">XLM</span>`;
        document.getElementById("send-balance-hint")!.textContent = `Balance: ${friendly} XLM`;
        $sendResult.style.display = "none";
        $sendSection.classList.add("hidden");
      } catch (err: any) {
        if (err.name === "NotAllowedError") {
          showError(passkeyBlockedHint("signing"));
        } else {
          showError(`Couldn't send: ${err.message}`);
        }
        $sendResult.style.display = "none";
      } finally {
        $sendSubmit.disabled = false;
      }
    });

    // Register passkey (when none exists yet)
    const $registerBtn = document.getElementById("register-btn") as HTMLButtonElement;
    $registerBtn.addEventListener("click", async () => {
      clearError();
      const support = checkPasskeySupport();
      if (!support.ok) {
        showError(support.message!);
        return;
      }
      try {
        $registerBtn.disabled = true;

        await withPasskeySheet(
          () => registerPasskey(),
          {
            title: "Set up your passkey",
            sub: `Confirm with ${passkey.label} to create it.`,
          },
        );

        document.getElementById("register-section")!.classList.add("hidden");
        toast({ msg: "Passkey ready", icon: "check" });
      } catch (err: any) {
        if (err.name === "NotAllowedError") {
          showError(passkeyBlockedHint("registration"));
        } else {
          showError(`Couldn't set up your passkey: ${err.message}`);
        }
      } finally {
        $registerBtn.disabled = false;
      }
    });
  }

  // --- Init ---

  initAccountCard();

  // Home link is set unconditionally near the top of the script (before any
  // code that can throw), so it doesn't need setting here.

  if (isSigningMode) {
    initSigningMode();
  } else {
    initHomeMode();
  }

  // Show the real, full address in the Receive panel.
  document.getElementById("receive-address")!.textContent = contractId || "(unknown)";

  // Fetch balance in background — REAL XLM, no fabricated fiat figure.
  const $balance = document.getElementById("xlm-balance")!;
  if (contractId) {
    fetchXlmBalance(contractId).then((balance) => {
      // Friendly grouping via money.formatXlm; keep the XLM figure truthful
      // (no fabricated fiat "$" balance — that was the prototype's mock).
      const friendly = formatXlm(balance);
      $balance.innerHTML = `${friendly} <span class="mut" style="font-size:24px;">XLM</span>`;
      currentBalanceXlm = balance;
      const hint = document.getElementById("send-balance-hint");
      if (hint) hint.textContent = `Balance: ${friendly} XLM`;
    }).catch(() => {
      $balance.textContent = "unavailable";
    });
  } else {
    $balance.textContent = "—";
  }

  // --- Name section ---

  if (SHOW_NAME_SECTION && contractId && !isSigningMode) {
    const $nameSection = document.getElementById("name-section")!;
    const $nameDisplay = document.getElementById("name-display")!;
    const $nameClaim = document.getElementById("name-claim")!;
    const $claimBtn = document.getElementById("claim-name-btn") as HTMLButtonElement;
    const $nameInput = document.getElementById("name-input") as HTMLInputElement;
    const $nameResult = document.getElementById("name-result")!;

    $nameSection.classList.remove("hidden");

    // The name is known authoritatively when we arrived via a name subdomain
    // (detectedName already resolved to THIS account); otherwise fall back to a
    // locally-saved name. On a name subdomain, persist it so later contract-id
    // visits in this browser show the name too. Either way: show the name (with
    // the contract id in the account card above), never the claim card.
    const existingName = detectedName ?? loadAccountName(contractId);
    if (existingName) {
      if (detectedName) saveAccountName(contractId, detectedName);
      $nameDisplay.classList.remove("hidden");
      document.getElementById("account-name")!.textContent = existingName;
      // Reflect the claimed name in the top bar nickname too.
      document.getElementById("account-nickname")!.textContent = existingName;
      const rootHost = stripSubdomain(window.location.host);
      const nameLink = document.getElementById("name-url") as HTMLAnchorElement;
      const nameHref = accountUrl(rootHost, existingName, "/account/");
      nameLink.textContent = nameHref.replace(/^\/\//, "");
      nameLink.href = nameHref;
    } else {
      $nameClaim.classList.remove("hidden");
    }


    // Helper: lazily get funded keypair for tx submission
    async function getNameKeypair(): Promise<Keypair> {
      const stored = localStorage.getItem("g2c:name-keypair");
      if (stored) return Keypair.fromSecret(stored);
      const kp = Keypair.random();
      const resp = await fetch(`https://friendbot.stellar.org?addr=${kp.publicKey()}`);
      if (!resp.ok) throw new Error(`Friendbot funding failed: ${resp.statusText}`);
      localStorage.setItem("g2c:name-keypair", kp.secret());
      return kp;
    }

    // Claim name button
    $claimBtn.addEventListener("click", async () => {
      clearError();
      const name = $nameInput.value.trim().toLowerCase();

      if (!name || !/^[a-z][a-z0-9]*$/.test(name) || name.length > 15) {
        showError("Name must be 1-15 characters, lowercase letters and digits only, starting with a letter.");
        return;
      }

      try {
        $claimBtn.disabled = true;
        $nameResult.style.display = "block";
        $nameResult.textContent = "Getting things ready…";

        // Load Buffer polyfill — needed by buildAuthHash and other SDK functions
        const { Buffer: B } = await import("buffer");
        if (typeof globalThis.Buffer === "undefined") {
          (globalThis as any).Buffer = B;
        }

        $nameResult.textContent = "Funding transaction keypair…";
        const keypair = await getNameKeypair();
        const server = new rpc.Server(RPC_URL);

        $nameResult.textContent = "Building transaction…";

        const sourceAccount = await server
          .getAccount(keypair.publicKey())
          .then((res: Account) => new Account(res.accountId(), res.sequenceNumber()));

        const simTx = new TransactionBuilder(sourceAccount, {
          fee: "10000000",
          networkPassphrase: Networks.TESTNET,
        })
          .addOperation(
            Operation.invokeContractFunction({
              contract: await fetchRegistryAddress("name-registry"),
              function: "register",
              args: [
                Address.fromString(contractId).toScVal(),
                nativeToScVal(name, { type: "string" }),
              ],
            })
          )
          .setTimeout(300)
          .build();

        $nameResult.textContent = "Simulating transaction…";
        const sim = await server.simulateTransaction(simTx);

        if (rpc.Api.isSimulationError(sim)) {
          throw new Error(`Simulation failed — name may already be taken. ${sim.error}`);
        }

        const successSim = sim as rpc.Api.SimulateTransactionSuccessResponse;

        // Extract auth entry and compute hash for passkey signing
        const authEntry = getAuthEntry(successSim);
        const lastLedger = successSim.latestLedger;
        // OZ v0.7 accounts verify the WebAuthn challenge against
        // sha256(signature_payload || context_rule_ids.to_xdr()), NOT the bare
        // signature_payload. injectPasskeySignature (in the nameresult return
        // flow) defaults contextRuleIds=[0], so sign computeAuthDigest(payload,
        // [0]) to match — mirrors walletSign.ts. Signing the bare payload makes
        // __check_auth trap with Auth/InvalidAction.
        const signaturePayload = buildAuthHash(authEntry, Networks.TESTNET, lastLedger);
        const authHashHex = buf2hex(computeAuthDigest(signaturePayload, [0]));

        // Assemble the transaction with simulation results so auth entries
        // are baked into the XDR (needed by injectPasskeySignature later)
        const assembled = rpc.assembleTransaction(simTx, successSim).build();

        // Store assembled transaction data for after signing redirect
        localStorage.setItem("g2c:name-txXdr", assembled.toXDR());
        localStorage.setItem("g2c:name-lastLedger", lastLedger.toString());
        localStorage.setItem("g2c:name-pending", name);

        $nameResult.textContent = "Taking you to confirm with your passkey…";

        // Redirect to the signing flow on this same account page
        const callback = `${window.location.protocol}//${window.location.host}/account/?nameresult=1`;
        const signUrl = `/account/?sign=${authHashHex}&callback=${encodeURIComponent(callback)}`;
        window.location.href = signUrl;
      } catch (err: any) {
        showError(`Couldn't claim that name: ${err.message}`);
        $nameResult.style.display = "none";
      } finally {
        $claimBtn.disabled = false;
      }
    });

    // --- Handle return from signing (name registration) ---

    if (params.get("nameresult") === "1") {
      const authenticatorData = params.get("authenticatorData");
      const clientDataJSON = params.get("clientDataJSON");
      const signatureHex = params.get("signature");
      const publicKeyHex = params.get("publicKey");

      if (params.get("error")) {
        showError("Name claim was cancelled.");
      } else if (authenticatorData && clientDataJSON && signatureHex && publicKeyHex) {
        (async () => {
          $nameResult.style.display = "block";
          try {
            // Load Buffer polyfill — needed by injectPasskeySignature and other SDK functions
            const { Buffer: B } = await import("buffer");
            if (typeof globalThis.Buffer === "undefined") {
              (globalThis as any).Buffer = B;
            }

            const txXdr = localStorage.getItem("g2c:name-txXdr");
            const lastLedgerStr = localStorage.getItem("g2c:name-lastLedger");
            const pendingName = localStorage.getItem("g2c:name-pending");
            const keypairSecret = localStorage.getItem("g2c:name-keypair");

            if (!txXdr || !lastLedgerStr || !keypairSecret || !pendingName) {
              throw new Error("Missing stored transaction data. Please try again.");
            }

            const lastLedger = parseInt(lastLedgerStr, 10);
            const keypair = Keypair.fromSecret(keypairSecret);
            // Read the verifier from the account's actual on-chain rule-0 signer.
            // Computing it from a hardcoded WASM hash yields a stale address that
            // won't match the registered signer, so __check_auth can't validate
            // the context (UnvalidatedContext / #3002). Mirrors walletSign.
            const verifierAddr = await fetchVerifierAddress(contractId);

            // Reconstruct transaction from stored XDR
            const authTxn = TransactionBuilder.fromXDR(txXdr, Networks.TESTNET) as Transaction;

            // Inject passkey signature
            injectPasskeySignature(
              authTxn,
              {
                authenticatorData: hex2buf(authenticatorData),
                clientDataJson: hex2buf(clientDataJSON),
                signature: hex2buf(signatureHex),
              },
              verifierAddr,
              hex2buf(publicKeyHex),
              lastLedger
            );

            // Re-simulate the now-signed tx in ENFORCE mode. This both verifies
            // the passkey auth before submit AND recomputes the resource
            // footprint to cover the storage keys __check_auth reads (the
            // verifier + the account's context-rule data). The initial assemble
            // (built from a sim with no auth entries) doesn't size those reads,
            // so submit would otherwise trap with an out-of-footprint error.
            // Default "record" mode IGNORES our injected signature entirely —
            // pass "enforce" so the simulator runs __check_auth against it.
            // (Mirrors primaryPasskeySigner.signAndSubmit / walletSign.)
            $nameResult.textContent = "Simulating signed transaction…";
            const server = new rpc.Server(RPC_URL);
            const sim = await server.simulateTransaction(authTxn, undefined, "enforce");

            if (rpc.Api.isSimulationError(sim) || rpc.Api.isSimulationRestore(sim)) {
              throw new Error(`Re-simulation failed: ${"error" in sim ? sim.error : "restore needed"}`);
            }
            const successSim = sim as rpc.Api.SimulateTransactionSuccessResponse;

            // Splice the fresh sorobanData (footprint + resource fee) into the
            // signed tx via cloneFrom. Do NOT use rpc.assembleTransaction here:
            // it rebuilds the auth entries from the sim's UNSIGNED templates and
            // silently discards our passkey signature. cloneFrom carries the
            // signed auth entry across intact.
            const newSorobanData = successSim.transactionData.build();
            const newResourceFee = BigInt(newSorobanData.resourceFee().toString());
            const classicFee =
              BigInt(authTxn.fee) -
              BigInt(
                (authTxn.toEnvelope().v1().tx().ext().value() as
                  | xdr.SorobanTransactionData
                  | undefined)
                  ?.resourceFee()
                  .toString() ?? "0"
              );
            const finalTx = TransactionBuilder.cloneFrom(authTxn, {
              fee: (classicFee + newResourceFee).toString(),
              sorobanData: newSorobanData,
              networkPassphrase: Networks.TESTNET,
            }).build();
            finalTx.sign(keypair);

            // Submit
            $nameResult.textContent = "Submitting transaction…";
            const sendResult = await server.sendTransaction(finalTx);

            if (sendResult.status === "ERROR") {
              throw new Error(`Transaction rejected: ${sendResult.errorResult?.toXDR("base64") ?? "unknown"}`);
            }

            // Poll for confirmation
            $nameResult.textContent = "Waiting for confirmation…";
            let getResult = await server.getTransaction(sendResult.hash);
            while (getResult.status === "NOT_FOUND") {
              await new Promise((r) => setTimeout(r, 1500));
              getResult = await server.getTransaction(sendResult.hash);
            }

            if (getResult.status === "SUCCESS") {
              saveAccountName(contractId, pendingName);

              // Clean up stored transaction data
              localStorage.removeItem("g2c:name-txXdr");
              localStorage.removeItem("g2c:name-lastLedger");
              localStorage.removeItem("g2c:name-pending");

              // Redirect to the claimed name's subdomain
              const rootHost = stripSubdomain(window.location.host);
              $nameResult.textContent = `Your Nido is now "${pendingName}" — taking you there…`;
              const nameUrl = accountUrl(rootHost, pendingName, "/account/");
              setTimeout(() => {
                window.location.href = `${window.location.protocol}${nameUrl}`;
              }, 1500);
            } else {
              throw new Error(`Transaction failed: ${getResult.status}`);
            }
          } catch (err: any) {
            showError(`Couldn't finish claiming your name: ${err.message}`);
            $nameResult.style.display = "none";
          }
        })();
      }
    }
  }
</script>
