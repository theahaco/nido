---
// Nido reskin of the status-message developer demo. Switched from BaseLayout to
// NidoLayout (Warm Nest design system). This is a behavior-preserving restyle:
// every id, query param, localStorage key, event name and handler in the
// <script> below is unchanged — only markup classes, copy, and presentation
// were touched. <Toast/> is mounted once here per the foundation contract.
import NidoLayout from "../../layouts/NidoLayout.astro";
import Toast from "../../components/Toast.astro";
import Logo from "../../components/Logo.astro";
import Icon from "../../components/Icon.astro";
---

<NidoLayout title="Status Message">
  <div class="col-scroll screen-in pad">
    <div class="topbar">
      <a href="/" class="topbar-mark"><Logo mark size={20} /></a>
      <div class="header-links">
        <a id="account-link" class="chip hidden">Open wallet</a>
        <a id="home-link" class="chip" href="/">Home</a>
      </div>
    </div>

    <header class="sm-head rise">
      <h1 class="disp sm-title">Leave a note in your nest</h1>
      <p class="sm-lead">
        Write a little status that lives on-chain, signed by your Nido with a
        passkey — no seed phrase, no extension. The steps below are a developer
        demo of how a dApp talks to a Nido smart account.
      </p>
    </header>

    <div id="error-box" role="alert" class="alert danger" style="display:none"></div>

    <!-- Delegation status banner -->
    <div id="delegation-status"></div>

    <div class="card-grid">
      <!-- Read current message -->
      <div class="grid-cell">
        <section class="card sm-card">
          <div class="section-label">Step 1 · Read</div>
          <h2 class="disp sm-h2">Read a note</h2>
          <div class="field">
            <label for="contract-input">Smart account C-address</label>
            <input id="contract-input" class="input mono" placeholder="C..." />
          </div>
          <div class="field">
            <button id="load-btn" class="btn soft">Load note</button>
          </div>
          <div id="current-message" class="sm-display hidden">
            <div class="label">Current note</div>
            <div class="value" id="message-value"></div>
          </div>
        </section>
      </div>

      <!-- Set new message -->
      <div class="grid-cell">
        <section class="card sm-card">
          <div class="section-label">Step 2 · Write</div>
          <h2 class="disp sm-h2">Set a new note</h2>
          <form id="set-form">
            <div class="field">
              <label for="message-input">New note</label>
              <input id="message-input" class="input" placeholder="Hello from my nest!" />
            </div>
            <div class="field">
              <button class="btn acc">
                <Icon name="send" size={18} color="#fff" /> Set note
              </button>
            </div>
          </form>
        </section>
      </div>

      <!-- Demo: dApp <-> wallet via @creit.tech/stellar-wallets-kit + selector -->
      <div class="grid-cell">
        <section id="kit-demo" class="card sm-card">
          <div class="section-label">Step 3 · Connect</div>
          <h2 class="disp sm-h2">Connect via stellar-wallets-kit</h2>
          <p class="sm-info">
            This panel talks to your wallet <strong>only through</strong>
            <code>@creit.tech/stellar-wallets-kit</code>. The
            <code>@nidohq/stellar-wallets-kit-module</code> registers Nido
            <strong>alongside</strong> the standard wallets (Freighter, xBull, …) so
            you pick one from the kit's selector modal — no Nido-specific connect
            code. For a Nido smart account, Set note builds the
            <code>udpate_message</code> tx, hands the XDR to
            <code>kit.signTransaction()</code> (which runs the passkey ceremony at
            <code>/sign/</code>), then submits the returned signed XDR.
          </p>
          <div class="field">
            <nido-wallet-button id="kit-wallet"></nido-wallet-button>
          </div>
          <div id="kit-non-nido" class="sm-display hidden">
            <div class="value">
              This demo signs as a Nido <strong>smart account</strong> (C-address).
              The selected wallet is a classic Stellar account — switch to a Nido
              wallet to set a note here.
            </div>
          </div>
          <div class="field">
            <label for="kit-message-input">New note (via kit)</label>
            <input id="kit-message-input" class="input" placeholder="Hello from the kit!" />
          </div>
          <div class="field">
            <button id="kit-set" class="btn acc" type="button" disabled>Set note via kit</button>
          </div>
          <div id="kit-status" class="sm-display hidden">
            <div class="label">Kit status</div>
            <div class="value" id="kit-status-value"></div>
            <a id="kit-tx-link" class="link" href="#" target="_blank" rel="noopener" style="display:none">View on Stellar Expert</a>
          </div>
        </section>
      </div>

      <!-- Result (shown after redirect back) -->
      <div class="grid-cell">
        <section id="result-section" class="card sm-card hidden">
          <div class="section-label">Result</div>
          <h2 class="disp sm-h2">All done</h2>
          <div id="submit-status" class="sm-display">
            <div class="label">Status</div>
            <div class="value" id="status-value">Submitting transaction...</div>
            <a id="tx-link" class="link" href="#" target="_blank" rel="noopener" style="display:none">View on Stellar Expert</a>
          </div>
        </section>
      </div>
    </div>
  </div>
  <Toast />
</NidoLayout>

<style>
  .header-links {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .header-links .chip { text-decoration: none; cursor: pointer; }

  .sm-head { padding: 6px 0 18px; }
  .sm-title {
    font-weight: 800;
    font-size: clamp(28px, 7vw, 36px);
    line-height: 1.04;
    margin: 0 0 10px;
  }
  .sm-lead { font-size: 15px; line-height: 1.55; color: var(--ink-soft); margin: 0; max-width: 38ch; }

  .sm-card { padding: 20px; margin-bottom: 16px; }
  .sm-h2 { font-weight: 800; font-size: 19px; margin: 6px 0 16px; }
  .sm-card .field { margin-bottom: 14px; }
  .sm-card .field:last-child { margin-bottom: 0; }

  .sm-info { font-size: 13px; line-height: 1.6; color: var(--ink-soft); margin: 0 0 16px; }
  .sm-info code {
    font-family: var(--mono); font-size: 0.88em;
    background: var(--chip); color: var(--ink-soft);
    padding: 1px 5px; border-radius: var(--r-sm);
  }

  .sm-display {
    background: var(--paper-3); border: 1px solid var(--line);
    border-radius: var(--r-md); padding: 14px 16px; margin: 14px 0 0;
  }
  .sm-display .label {
    font-size: 11px; font-weight: 800; letter-spacing: .04em;
    text-transform: uppercase; color: var(--mut);
  }
  .sm-display .value { font-size: 15px; color: var(--ink); margin-top: 5px; word-break: break-word; }
  .sm-display a { display: inline-block; margin-top: 8px; font-size: 13px; }

  /* ---- <nido-wallet-button> reskin (Nido tokens) ---- */
  nido-wallet-button .nido-wb {
    display: flex; align-items: center; flex-wrap: wrap; gap: 10px;
  }
  nido-wallet-button .nido-wb-connect { width: 100%; }
  nido-wallet-button .nido-wb-meta {
    display: inline-flex; align-items: center; gap: 9px; flex: 1; min-width: 0;
  }
  nido-wallet-button .nido-wb-addr {
    font-family: var(--mono); font-size: 12.5px; color: var(--ink-soft);
    word-break: break-all;
  }
  nido-wallet-button .nido-wb-warning {
    flex-basis: 100%; font-size: 12.5px; color: var(--warn);
    background: var(--warn-soft); border-radius: var(--r-sm); padding: 8px 11px;
  }
  nido-wallet-button .nido-wb-warning a { color: var(--warn); font-weight: 700; }
  nido-wallet-button .nido-wb-error {
    flex-basis: 100%; font-size: 12.5px; color: var(--danger);
  }
</style>

<script>
  import { Buffer } from "buffer";
  import { Client } from "@nidohq/status-message";
  import {
    buildAuthHash,
    computeAuthDigest,
    getAuthEntry,
    injectPasskeySignature,
    hex2buf,
    buf2hex,
    accountUrl,
    stripSubdomain,
    loadSessionKeyMaterial,
    forgetSessionKeyMaterial,
    signWithSessionPasskey,
    fetchRegistryAddress,
  } from "@nidohq/passkey-sdk";
  import { findRuleForPubkey, fetchVerifierAddress } from "../../lib/policyChainFetch.js";
  import { startDelegation, readDelegationReturn, consumePendingDelegation } from "../../lib/delegationHandover.js";
  import { Keypair, Networks, TransactionBuilder, Transaction, rpc, xdr } from "@stellar/stellar-sdk";
  import { defineNidoWalletButton, WALLET_CHANGED_EVENT } from "../../components/nido-wallet-button.js";
  import { signTransaction as kitSignTransaction, isNidoWallet, type WalletSession } from "../../lib/walletConnect.js";

  const RPC_URL = "https://soroban-testnet.stellar.org";
  // Resolved by name via the on-chain registry (with a single hardcoded
  // fallback inside `fetchRegistryAddress` for registry outages). Previously
  // hardcoded here so bindings could be regenerated without --contract-id;
  // routing through the registry keeps that property while making a redeploy
  // a registry-only change.
  const STATUS_CONTRACT = await fetchRegistryAddress("status-message");

  // WebAuthn verifier — resolved per-account from chain when signing.
  // Was previously a deterministic derivation from FACTORY+wasm_hash,
  // which broke once the factory stopped lazy-deploying its own
  // verifier and instead resolved one via stellar-registry, AND once
  // the registered verifier was redeployed (different address).
  // Now: read it off the account's own rule so we always cite the
  // verifier the smart account actually trusts.

  // --- UI refs ---

  const $errorBox = document.getElementById("error-box")!;
  const $contractInput = document.getElementById("contract-input") as HTMLInputElement;
  const $loadBtn = document.getElementById("load-btn") as HTMLButtonElement;
  const $currentMessage = document.getElementById("current-message")!;
  const $messageValue = document.getElementById("message-value")!;
  const $messageInput = document.getElementById("message-input") as HTMLInputElement;
  const $setForm = document.getElementById("set-form") as HTMLButtonElement;
  const $resultSection = document.getElementById("result-section")!;
  const $statusValue = document.getElementById("status-value")!;
  const $txLink = document.getElementById("tx-link") as HTMLAnchorElement;

  // --- UI helpers ---

  function showError(msg: string) {
    $errorBox.textContent = msg;
    $errorBox.style.display = "block";
  }

  function clearError() {
    $errorBox.style.display = "none";
  }

  // --- Keypair management ---

  let keypairReady: Promise<Keypair>;
  const storedSecret = localStorage.getItem("sm:keypairSecret");
  if (storedSecret) {
    keypairReady = Promise.resolve(Keypair.fromSecret(storedSecret));
  } else {
    keypairReady = (async () => {
      const kp = Keypair.random();
      const resp = await fetch(
        `https://friendbot.stellar.org?addr=${kp.publicKey()}`
      );
      if (!resp.ok) throw new Error(`Friendbot funding failed: ${resp.statusText}`);
      localStorage.setItem("sm:keypairSecret", kp.secret());
      return kp;
    })();
  }

  // --- URL params ---

  const params = new URLSearchParams(window.location.search);
  const contractParam = params.get("contract");
  const isResult = params.get("result") === "1";

  if (contractParam) {
    $contractInput.value = contractParam;
  }

  // If we just came back from the wallet's delegate flow, surface the
  // outcome and clean the URL so reloads don't re-trigger the banner.
  {
    const ret = readDelegationReturn();
    if (ret) {
      // The wallet's return redirect carries only `?delegation=...` — it
      // overwrites our returnUrl query string, so the account we delegated for
      // is NOT in the URL. Recover it from the record startDelegation
      // persisted and repopulate the input, so the delegation banner (and the
      // in-page session-key signing path) find the saved material instead of
      // the user having to re-paste the C-address.
      const pending = consumePendingDelegation();
      if (pending?.account && !$contractInput.value) {
        $contractInput.value = pending.account;
      }
      alert(
        ret === "ok"
          ? "Delegation succeeded. The dApp will now sign in-page for this contract."
          : "Delegation cancelled. Local session-key material was kept; the next attempt will overwrite it.",
      );
      // Drop ?delegation but keep the account in the URL so a reload stays on
      // this contract (the pending record is single-use and already consumed).
      const clean = new URL(window.location.href);
      clean.searchParams.delete("delegation");
      const acc = $contractInput.value.trim();
      if (acc) clean.searchParams.set("contract", acc);
      window.history.replaceState({}, "", clean.toString());
    }
  }

  // --- Delegation status banner ---

  function updateDelegationBanner(account: string) {
    const $status = document.getElementById("delegation-status")!;
    if (!account) {
      $status.innerHTML = `
        <div class="card sm-card" style="background:var(--paper-3);margin-bottom:16px">
          <p style="margin:0 0 12px 0;font-size:13px;line-height:1.55;color:var(--ink-soft)">
            Type your smart account address above, then delegate this dApp
            so signing stays in-page (no wallet round-trip per note).
          </p>
          <button id="delegate-button" class="btn soft" disabled>
            Delegate this dApp →
          </button>
        </div>`;
      return;
    }
    const material = loadSessionKeyMaterial(account, STATUS_CONTRACT);
    const delegatedBanner = material
      ? `<p style="margin:0 0 8px 0;font-size:14px;color:var(--good)">
           <strong>Delegated</strong> — signs in-page with a dApp-scoped passkey.
           <button id="forget-delegation" class="link" style="background:none;border:none;cursor:pointer;margin-left:6px;font-size:13px;font-weight:700">Forget delegation</button>
         </p>
         <p style="margin:0 0 12px 0;font-size:13px;line-height:1.55;color:var(--ink-soft)">
           Each action prompts your authenticator (Touch ID / device unlock) at this origin;
           no wallet round-trip. Re-delegate to replace this session passkey with a fresh one.
         </p>`
      : `<p style="margin:0 0 8px 0;font-size:14px;color:var(--ink)">
           <strong>Not delegated.</strong> Every action will redirect to your
           wallet for a passkey prompt.
         </p>
         <p style="margin:0 0 12px 0;font-size:13px;line-height:1.55;color:var(--ink-soft)">
           Delegate this dApp to skip the round-trip: a passkey scoped to
           the status-message contract is created at this origin. The
           private key never leaves your authenticator — XSS at this site
           can't sign for you. Each action still needs a biometric/device
           unlock here, just not a full wallet detour.
         </p>`;
    $status.innerHTML = `
      <div class="card sm-card" style="background:var(--paper-3);margin-bottom:16px">
        ${delegatedBanner}
        <button id="delegate-button" class="btn soft">
          ${material ? "Re-delegate this dApp →" : "Delegate this dApp →"}
        </button>
      </div>`;
    if (material) {
      document.getElementById("forget-delegation")!.addEventListener("click", () => {
        forgetSessionKeyMaterial(account, STATUS_CONTRACT);
        location.reload();
      });
    }
    document.getElementById("delegate-button")!.addEventListener("click", async () => {
        const acc = $contractInput.value.trim();
        if (!acc) {
          alert("Enter your smart account address first.");
          return;
        }
        // Build the wallet origin. accountUrl returns a protocol-relative
        // URL ("//<acc>.<base>/" in prod, "//<acc>--N.<base>/" in PR
        // previews), which we feed to URL() to extract the origin. Doing it
        // manually with `${acc}.${stripSubdomain(host)}` drops the preview
        // suffix in previews because stripSubdomain returns "pr-N.<base>"
        // (preserves the prefix as its own segment).
        const path = accountUrl(window.location.host, acc, "/");
        const walletOrigin = new URL(`${window.location.protocol}${path}`).origin;
        try {
          // Generates the session key in *this* origin, persists private bytes
          // locally, then full-page redirects to the wallet with the public
          // key + scope in URL params. Wallet signs and redirects back.
          await startDelegation({
            walletOrigin,
            account: acc,
            targetContract: STATUS_CONTRACT,
            duration: "24h",
            returnUrl: window.location.href,
            label: "status-message",
          });
        } catch (err: unknown) {
          const msg = err instanceof Error ? err.message : String(err);
          alert(`Delegation failed: ${msg}`);
        }
      });
  }

  // --- Header navigation links ---
  //
  // The page lives on `status-message[.--N].mysoroban.xyz`, so a static
  // <a href="/"> wouldn't go to the wallet — it'd stay on the dApp
  // subdomain (the worker rewrites `/` here back to `/status-message/`).
  // Compute the apex at runtime and route Home there. Account link
  // appears whenever a contract is in the input.
  const $homeLink = document.getElementById("home-link") as HTMLAnchorElement;
  const $accountLink = document.getElementById("account-link") as HTMLAnchorElement;
  const apexHost = stripSubdomain(window.location.host);
  $homeLink.href = `${window.location.protocol}//${apexHost}/`;

  function updateAccountLink(account: string) {
    if (account && /^C[A-Z0-9]{55}$/.test(account)) {
      $accountLink.href = accountUrl(window.location.host, account, "/account/");
      $accountLink.classList.remove("hidden");
    } else {
      $accountLink.classList.add("hidden");
    }
  }

  // Show banner + nav link for initial account value (from URL param or empty)
  updateDelegationBanner($contractInput.value.trim());
  updateAccountLink($contractInput.value.trim());

  // Update banner whenever the account input changes
  $contractInput.addEventListener("input", () => {
    const v = $contractInput.value.trim();
    updateDelegationBanner(v);
    updateAccountLink(v);
  });

  // --- Load message ---

  async function loadMessage(contract: string) {
    const keypair = await keypairReady;
    const client = new Client({
      contractId: STATUS_CONTRACT,
      networkPassphrase: Networks.TESTNET,
      rpcUrl: RPC_URL,
      publicKey: keypair.publicKey(),
    });

    const tx = await client.get_message({ author: contract });
    $currentMessage.classList.remove("hidden");
    $messageValue.textContent = tx.result ?? "No message set";
  }

  $loadBtn.addEventListener("click", async () => {
    clearError();
    const contract = $contractInput.value.trim();
    if (!contract) {
      showError("Enter a smart account C-address");
      return;
    }

    try {
      $loadBtn.disabled = true;
      $loadBtn.textContent = "Loading...";
      await loadMessage(contract);
    } catch (err: any) {
      showError(`Failed to load message: ${err.message}`);
    } finally {
      $loadBtn.disabled = false;
      $loadBtn.textContent = "Load Message";
    }
  });

  // --- Set message ---

  $setForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearError();
    const contract = $contractInput.value.trim();
    const message = $messageInput.value.trim();

    if (!contract) {
      showError("Enter a smart account C-address");
      return;
    }
    if (!message) {
      showError("Enter a message");
      return;
    }

    try {
      $setForm.disabled = true;
      $setForm.textContent = "Building transaction...";

      const keypair = await keypairReady;
      const client = new Client({
        contractId: STATUS_CONTRACT,
        networkPassphrase: Networks.TESTNET,
        rpcUrl: RPC_URL,
        publicKey: keypair.publicKey(),
      });

      const tx = await client.udpate_message({ message, author: contract }, { simulate: true } );
      const sim = tx.simulation as rpc.Api.SimulateTransactionSuccessResponse;

      // Extract auth entry and compute hash
      const authEntry = getAuthEntry(sim);
      const lastLedger = sim.latestLedger;
      const authHash = buildAuthHash(authEntry, Networks.TESTNET, lastLedger);

      // --- Session-passkey in-page signing path ---
      const material = loadSessionKeyMaterial(contract, STATUS_CONTRACT);
      if (material) {
        $setForm.textContent = "Finding session rule on chain...";

        // Discover which context rule on this account contains our
        // session-passkey signer. The wallet's add_context_rule assigned
        // some non-zero rule id when it installed the delegation; we
        // can't hard-code [0] (that's the default rule for the primary
        // passkey) and can't easily plumb the id back from the wallet's
        // redirect either. Querying every time is cheap and self-healing:
        // if the install tx never landed, this returns null and we tear
        // the stale localStorage entry down.
        const ruleId = await findRuleForPubkey(contract, material.publicKey);
        if (ruleId === null) {
          forgetSessionKeyMaterial(contract, STATUS_CONTRACT);
          throw new Error(
            "Session passkey is not installed on chain (the delegation never " +
              "actually committed). Please re-delegate this dApp."
          );
        }
        const contextRuleIds = [ruleId];

        // Look up the verifier the smart account actually trusts —
        // not a hardcoded address. Once issue #26 (registry resolution)
        // is fully wired this and `fetchVerifierAddress` collapse into
        // a single registry call.
        const verifierAddress = await fetchVerifierAddress(contract);

        $setForm.textContent = "Touch your authenticator to sign...";

        // OZ v0.7+ smart accounts verify against
        //   auth_digest = sha256(signature_payload || context_rule_ids.to_xdr())
        // — NOT the raw signature_payload. Sign that digest.
        const authDigest = computeAuthDigest(
          new Uint8Array(authHash),
          contextRuleIds,
        );
        const parsed = await signWithSessionPasskey(
          material.credentialId,
          new Uint8Array(authDigest),
        );

        const sessionPubkey = hex2buf(material.publicKey);

        // `tx.built` is ALREADY the assembled tx from the bindings'
        // internal simulate. Re-running rpc.assembleTransaction on it
        // hits the cross-bundle `instanceof Transaction` check and
        // throws "expected a 'Transaction', got: [object Object]".
        const authTxn = tx.built!;

        // Inject the session-passkey signature in OZ v0.7 AuthPayload
        // shape, threading the same contextRuleIds so the chain-side
        // recomputed digest matches our signature.
        injectPasskeySignature(
          authTxn,
          parsed,
          verifierAddress,
          sessionPubkey,
          lastLedger,
          undefined,
          contextRuleIds,
        );

        $setForm.textContent = "Submitting...";

        // Re-simulate the signed tx in enforce mode — both as a
        // pre-submit auth sanity check AND to recompute the resource
        // footprint so it covers __check_auth's reads. The bindings'
        // internal simulate built tx.built with auth=[] (had to, to
        // dodge recording-mode trapping on unsigned auth templates),
        // so the assembled footprint covers the operation only. Apply
        // the enforce-mode sim's transactionData via
        // TransactionBuilder.cloneFrom (preserves auth entries) instead
        // of rpc.assembleTransaction (which rebuilds + strips auth) —
        // same refit pattern as primaryPasskeySigner.
        const server = new rpc.Server(RPC_URL);
        const sim2 = await server.simulateTransaction(authTxn, undefined, 'enforce');
        if (rpc.Api.isSimulationError(sim2) || rpc.Api.isSimulationRestore(sim2)) {
          throw new Error(`Re-simulation failed: ${"error" in sim2 ? sim2.error : "restore needed"}`);
        }
        const successSim2 = sim2 as rpc.Api.SimulateTransactionSuccessResponse;
        const newSorobanData = successSim2.transactionData.build();
        const newResourceFee = BigInt(newSorobanData.resourceFee().toString());

        // Round-trip authTxn through XDR to materialize a Transaction in
        // the PAGE's @stellar/stellar-sdk module instance — otherwise
        // TransactionBuilder.cloneFrom's `instanceof Transaction` check
        // fails because authTxn was built by the bindings' bundled SDK
        // module copy. Same gotcha that broke the original
        // rpc.assembleTransaction(tx.built, sim) call; same workaround.
        // The signed auth entries are part of the XDR so they survive
        // the round-trip intact.
        const reparsedAuthTxn = TransactionBuilder.fromXDR(
          authTxn.toEnvelope().toXDR('base64'),
          Networks.TESTNET,
        ) as Transaction;
        const oldResourceFee = BigInt(
          (reparsedAuthTxn.toEnvelope().v1().tx().ext().value() as xdr.SorobanTransactionData | undefined)
            ?.resourceFee().toString() ?? '0'
        );
        const classicFee = BigInt(reparsedAuthTxn.fee) - oldResourceFee;
        const finalTx = TransactionBuilder.cloneFrom(reparsedAuthTxn, {
          fee: (classicFee + newResourceFee).toString(),
          sorobanData: newSorobanData,
          networkPassphrase: Networks.TESTNET,
        }).build();
        finalTx.sign(keypair);

        $resultSection.classList.remove("hidden");
        $statusValue.textContent = "Submitting transaction...";

        const sendResult = await server.sendTransaction(finalTx);
        if (sendResult.status === "ERROR") {
          throw new Error(`Transaction rejected: ${sendResult.errorResult?.toXDR("base64") ?? "unknown"}`);
        }

        $statusValue.textContent = "Waiting for confirmation...";
        let getResult = await server.getTransaction(sendResult.hash);
        while (getResult.status === "NOT_FOUND") {
          await new Promise((r) => setTimeout(r, 1500));
          getResult = await server.getTransaction(sendResult.hash);
        }

        if (getResult.status === "SUCCESS") {
          $statusValue.textContent = "Message updated successfully!";
          $txLink.href = `https://stellar.expert/explorer/testnet/tx/${sendResult.hash}`;
          $txLink.style.display = "inline";
          try { await loadMessage(contract); } catch (_) { /* non-critical */ }
        } else {
          throw new Error(`Transaction failed: ${getResult.status}`);
        }

        $setForm.disabled = false;
        $setForm.textContent = "Set note";
        return;
      }

      // --- Fallback: redirect to wallet for passkey signing ---
      // OZ v0.7 accounts verify against computeAuthDigest(signature_payload,
      // context_rule_ids), NOT the bare signature_payload. The /account/
      // signing-mode signs this challenge with the PRIMARY passkey on the
      // Default rule, and the callback below injects with the default
      // contextRuleIds=[0] — so sign the [0] digest, else the verifier rejects
      // with ChallengeInvalid (#3114). Mirrors account/index.astro name-claim.
      const authHashHex = buf2hex(computeAuthDigest(new Uint8Array(authHash), [0]));

      // Store transaction data for after redirect
      localStorage.setItem("sm:txXdr", tx.built!.toXDR());
      localStorage.setItem("sm:lastLedger", lastLedger.toString());
      localStorage.setItem("sm:contract", contract);

      // Redirect to account subdomain for passkey signing
      const callback = `${window.location.origin}/status-message/?result=1&contract=${contract}`;
      const signUrl = accountUrl(
        window.location.host,
        contract,
        `/account/?sign=${authHashHex}&callback=${encodeURIComponent(callback)}`
      );
      window.location.href = signUrl;
    } catch (err: any) {
      showError(`Failed to build transaction: ${err.message}`);
      $setForm.disabled = false;
      $setForm.textContent = "Set note";
    }
  });

  // --- Handle return from signing ---

  if (isResult) {
    const authenticatorData = params.get("authenticatorData");
    const clientDataJSON = params.get("clientDataJSON");
    const signature = params.get("signature");
    const publicKeyHex = params.get("publicKey");

    if (params.get("error")) {
      showError("Signature request was denied.");
    } else if (authenticatorData && clientDataJSON && signature && publicKeyHex) {
      (async () => {
        try {
          const txXdr = localStorage.getItem("sm:txXdr");
          const lastLedgerStr = localStorage.getItem("sm:lastLedger");
          const keypairSecret = localStorage.getItem("sm:keypairSecret");
          const callbackContract = localStorage.getItem("sm:contract");

          if (!txXdr || !lastLedgerStr || !keypairSecret || !callbackContract) {
            throw new Error("Missing stored transaction data. Please try again.");
          }

          const lastLedger = parseInt(lastLedgerStr, 10);
          const keypair = Keypair.fromSecret(keypairSecret);

          // Reconstruct transaction from stored XDR
          const authTxn = TransactionBuilder.fromXDR(txXdr, Networks.TESTNET) as Transaction;

          // Inject passkey signature into auth entry (OZ smart account format).
          // Read the verifier off the account's own rule rather than a stale
          // hardcoded derivation — same reason as the in-page session path.
          const verifierAddress = await fetchVerifierAddress(callbackContract);
          injectPasskeySignature(
            authTxn,
            {
              authenticatorData: hex2buf(authenticatorData),
              clientDataJson: hex2buf(clientDataJSON),
              signature: hex2buf(signature),
            },
            verifierAddress,
            hex2buf(publicKeyHex),
            lastLedger
          );

          // Re-simulate with real signature for accurate resource estimates
          const server = new rpc.Server(RPC_URL);
          const sim = await server.simulateTransaction(authTxn);

          if (rpc.Api.isSimulationError(sim) || rpc.Api.isSimulationRestore(sim)) {
            throw new Error(`Re-simulation failed: ${"error" in sim ? sim.error : "restore needed"}`);
          }

          // Re-assemble with updated resources/fees
          const finalTx = rpc.assembleTransaction(authTxn, sim).build();

          // Sign envelope with source keypair
          finalTx.sign(keypair);

          // Submit to the network
          $resultSection.classList.remove("hidden");
          $statusValue.textContent = "Submitting transaction...";
          const sendResult = await server.sendTransaction(finalTx);

          if (sendResult.status === "ERROR") {
            throw new Error(`Transaction rejected: ${sendResult.errorResult?.toXDR("base64") ?? "unknown"}`);
          }

          // Poll for confirmation
          $statusValue.textContent = "Waiting for confirmation...";
          let getResult = await server.getTransaction(sendResult.hash);
          while (getResult.status === "NOT_FOUND") {
            await new Promise((r) => setTimeout(r, 1500));
            getResult = await server.getTransaction(sendResult.hash);
          }

          if (getResult.status === "SUCCESS") {
            $statusValue.textContent = "Message updated successfully!";
            $txLink.href = `https://stellar.expert/explorer/testnet/tx/${sendResult.hash}`;
            $txLink.style.display = "inline";

            // Reload the current message
            const contract = $contractInput.value.trim();
            if (contract) {
              try {
                await loadMessage(contract);
              } catch (_) {
                // non-critical, ignore
              }
            }
          } else {
            throw new Error(`Transaction failed: ${getResult.status}`);
          }

          // Clean up stored transaction data and URL params
          localStorage.removeItem("sm:txXdr");
          localStorage.removeItem("sm:lastLedger");
          localStorage.removeItem("sm:contract");
          const cleanUrl = new URL(window.location.href);
          cleanUrl.search = contractParam ? `?contract=${contractParam}` : "";
          window.history.replaceState({}, "", cleanUrl);
        } catch (err: any) {
          showError(`Failed: ${err.message}`);
        }
      })();
    }
  }

  // ===================================================================
  // Demo: drive a wallet through @creit.tech/stellar-wallets-kit's selector
  // ===================================================================
  //
  // Everything below is what an *arbitrary* dApp would write: it knows
  // nothing about Nido passkeys, subdomains, or the WebAuthn verifier. It only
  // knows the kit API (`connect`/`signTransaction`) and that it registered the
  // Nido module ALONGSIDE the standard wallets (via the reusable helper in
  // ../../lib/walletConnect.ts). The user picks a wallet from the kit's
  // selector modal; the module + /connect/ + /sign/ pages do all the
  // Nido-specific work behind the redirect ceremony.

  {
    const $kitWallet = document.getElementById("kit-wallet")!;

    // Tell the button the Nido apex base BEFORE it upgrades: the page lives at
    // `status-message[.--N].<base>`, and `stripSubdomain` recovers the apex
    // (preserving the preview prefix, which a naive last-two-labels
    // split would drop). Set the attribute first so the element's
    // connectedCallback reads it when it inits the kit.
    const apexBase = `${window.location.protocol}//${stripSubdomain(window.location.host)}`;
    $kitWallet.setAttribute("base", apexBase);
    $kitWallet.setAttribute("network-passphrase", Networks.TESTNET);

    // Register the <nido-wallet-button> custom element. It inits the kit once
    // (Nido + standard modules) and owns connect/disconnect/session-restore.
    defineNidoWalletButton();
    const $kitMessageInput = document.getElementById("kit-message-input") as HTMLInputElement;
    const $kitSet = document.getElementById("kit-set") as HTMLButtonElement;
    const $kitStatus = document.getElementById("kit-status")!;
    const $kitStatusValue = document.getElementById("kit-status-value")!;
    const $kitTxLink = document.getElementById("kit-tx-link") as HTMLAnchorElement;
    const $kitNonNido = document.getElementById("kit-non-nido")!;

    // The currently connected session, or null. Only Nido (C-address) sessions
    // can drive the smart-account set-message flow below.
    let kitSession: WalletSession | null = null;

    function kitSetStatus(msg: string) {
      $kitStatus.classList.remove("hidden");
      $kitStatusValue.textContent = msg;
    }

    function applySession(session: WalletSession | null) {
      kitSession = session;
      if (session && isNidoWallet(session.walletId)) {
        // A Nido smart account: enable set-message and feed the C-address into
        // the read/load + delegation sections above.
        $kitNonNido.classList.add("hidden");
        $kitSet.disabled = false;
        $contractInput.value = session.walletAddress;
        updateDelegationBanner(session.walletAddress);
        updateAccountLink(session.walletAddress);
      } else if (session) {
        // A classic G-address wallet — degrade gracefully: the set-message
        // flow signs as a smart account, so it can't use this wallet.
        $kitNonNido.classList.remove("hidden");
        $kitSet.disabled = true;
      } else {
        $kitNonNido.classList.add("hidden");
        $kitSet.disabled = true;
      }
    }

    // The custom element restores any persisted session on load and emits the
    // change event; listen for connect/disconnect/restore.
    $kitWallet.addEventListener(WALLET_CHANGED_EVENT, (e) => {
      applySession((e as CustomEvent<WalletSession | null>).detail);
    });

    $kitSet.addEventListener("click", async () => {
      clearError();
      const message = $kitMessageInput.value.trim();
      const kitAccount = kitSession?.walletAddress ?? null;
      if (!kitAccount || !kitSession || !isNidoWallet(kitSession.walletId)) {
        showError("Connect a Nido smart-account wallet first.");
        return;
      }
      if (!message) { showError("Enter a message to set via the kit."); return; }

      $kitSet.disabled = true;
      const origLabel = $kitSet.textContent;
      try {
        const keypair = await keypairReady;

        // 1. Build the Soroban tx XDR for `udpate_message` with the connected
        //    smart account as `author`. The funded G-address is the tx source
        //    (fee payer); the smart account authorizes via its passkey.
        kitSetStatus("Building transaction…");
        const client = new Client({
          contractId: STATUS_CONTRACT,
          networkPassphrase: Networks.TESTNET,
          rpcUrl: RPC_URL,
          publicKey: keypair.publicKey(),
        });
        const tx = await client.udpate_message(
          { message, author: kitAccount },
          { simulate: true },
        );
        const unsignedXdr = tx.built!.toXDR();

        // 2. Hand the XDR to the kit. The Nido module opens `<account>.<base>/sign/`,
        //    runs the passkey ceremony, and returns the XDR with the smart
        //    account's auth entry signed (SEP-43: signing != submitting).
        kitSetStatus("Awaiting wallet signature (passkey)…");
        const { signedTxXdr } = await kitSignTransaction(unsignedXdr, {
          networkPassphrase: Networks.TESTNET,
          address: kitAccount,
        });

        // 3. The returned tx is signed by the smart account but still needs the
        //    fee-payer (tx source) signature. Add it and submit.
        kitSetStatus("Submitting signed transaction…");
        const server = new rpc.Server(RPC_URL);
        const signedTx = TransactionBuilder.fromXDR(signedTxXdr, Networks.TESTNET) as Transaction;
        signedTx.sign(keypair);

        const sendResult = await server.sendTransaction(signedTx);
        if (sendResult.status === "ERROR") {
          throw new Error(`Rejected: ${sendResult.errorResult?.toXDR("base64") ?? "unknown"}`);
        }

        kitSetStatus("Waiting for confirmation…");
        let getResult = await server.getTransaction(sendResult.hash);
        while (getResult.status === "NOT_FOUND") {
          await new Promise((r) => setTimeout(r, 1500));
          getResult = await server.getTransaction(sendResult.hash);
        }

        if (getResult.status === "SUCCESS") {
          kitSetStatus("Message updated via the kit!");
          $kitTxLink.href = `https://stellar.expert/explorer/testnet/tx/${sendResult.hash}`;
          $kitTxLink.style.display = "inline";
          try { await loadMessage(kitAccount); } catch (_) { /* non-critical */ }
        } else {
          throw new Error(`Transaction failed: ${getResult.status}`);
        }
      } catch (err: any) {
        kitSetStatus(`Failed: ${err.message ?? err}`);
        showError(`Kit set-message failed: ${err.message ?? err}`);
      } finally {
        $kitSet.disabled = false;
        $kitSet.textContent = origLabel;
      }
    });
  }
</script>
