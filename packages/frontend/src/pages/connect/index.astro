---
// Nido reskin of the dApp connect / account-picker screen (chunk 2D).
//
// SECURITY-CRITICAL: the #34 redirect ceremony (postResultToOpener) and the
// return / dapp same-origin validation (`validatedReturn`) are preserved
// BYTE-FOR-BYTE from the BaseLayout original. Only the markup, copy (Nido
// voice), and the account-picker visual are new. No signing happens here.
import NidoLayout from '../../layouts/NidoLayout.astro';
import Logo from '../../components/Logo.astro';
import Icon from '../../components/Icon.astro';
import Toast from '../../components/Toast.astro';
---
<NidoLayout title="Connect to dApp" shell="focused">
  <div class="topbar">
    <Logo mark size={20} />
    <span class="chip good"><span class="dot"></span> Read-only</span>
  </div>

  <div class="col-scroll">
    <div class="pad screen-in">
      <div class="eyebrow">
        <span class="chip acc"><Icon name="link" size={14} stroke={2} /> Connection request</span>
      </div>

      <h1 class="disp head">Choose which Nido to use</h1>
      <p class="lead mut">
        <code class="hl" id="dapp-origin">…</code> wants to connect. Only the
        account's public address is shared — no signing happens here.
      </p>

      <div id="error-box" class="alert danger" style="display:none"></div>

      <section id="accounts-section">
        <div id="accounts-list" class="picker"></div>
        <div id="no-accounts" class="empty hidden">
          <Icon name="wallet" size={26} stroke={1.7} color="var(--mut)" />
          <p>No accounts on this device. <a class="link" href="/">Create one first</a>, then come back.</p>
        </div>
      </section>
    </div>
  </div>

  <div class="footer">
    <button id="cancel" type="button" class="btn ghost block">Cancel</button>
  </div>

  <Toast />
</NidoLayout>

<style>
  .topbar { justify-content: space-between; }
  .eyebrow { margin: 4px 0 14px; }
  .head { font-weight: 800; font-size: 30px; margin: 0 0 8px; }
  .lead { font-size: 14.5px; line-height: 1.55; margin: 0 0 20px; }
  code.hl {
    font-family: var(--mono); font-size: 12.5px; color: var(--acc-ink);
    background: var(--acc-soft); padding: 1px 7px; border-radius: var(--r-sm);
    word-break: break-all;
  }

  .picker { display: flex; flex-direction: column; gap: 10px; }

  .empty {
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    text-align: center; padding: 28px 16px; color: var(--mut);
    border: 1px dashed var(--line); border-radius: var(--r-lg);
  }
  .empty p { margin: 0; font-size: 13.5px; line-height: 1.5; }

  .alert {
    border-radius: var(--r-md); padding: 12px 14px; margin-bottom: 14px;
    font-size: 13px; line-height: 1.5; font-weight: 600;
  }
  .alert.danger { background: var(--acc-soft); color: var(--danger); }

  .footer {
    padding: 14px 22px calc(18px + env(safe-area-inset-bottom));
    border-top: 1px solid var(--line); background: var(--paper-2);
  }
</style>

<style is:global>
  /* Account-picker row — walletswitch-style tappable card. Global so the
     buttons created in the page <script> are matched. */
  .picker .account-row {
    display: flex; align-items: center; gap: 13px; width: 100%;
    background: var(--paper-2); border: 1px solid var(--line);
    border-radius: var(--r-lg); padding: 13px 15px; cursor: pointer;
    text-align: left; color: inherit; font: inherit;
    transition: border-color .15s, box-shadow .15s, transform .14s cubic-bezier(.2,.7,.3,1);
  }
  .picker .account-row:hover { border-color: var(--acc); box-shadow: var(--sh-1); }
  .picker .account-row:active { transform: scale(.985); }
  .picker .account-row:disabled { opacity: .42; cursor: not-allowed; }
  .picker .account-info { flex: 1; min-width: 0; }
  .picker .account-name { font-size: 14.5px; font-weight: 700; color: var(--ink); }
  .picker .account-address { font-family: var(--mono); font-size: 12px; color: var(--mut); word-break: break-all; }
  .picker .account-row .chev { color: var(--mut); flex: 0 0 auto; }
</style>

<script>
  import { loadAccounts, loadAccountName, isContractId } from '@g2c/passkey-sdk';
  import { postResultToOpener } from '@g2c/stellar-wallets-kit-module';
  import { shortAddr } from '../../lib/address';

  // Deterministic identicon avatar — FNV-1a hash → hsl radial gradient.
  // Mirrors src/components/Avatar.astro so picker rows built at runtime match
  // the Nido avatar look without a server render.
  function avatarEl(seed: string): HTMLElement {
    let h = 2166136261;
    for (let i = 0; i < seed.length; i++) { h ^= seed.charCodeAt(i); h = Math.imul(h, 16777619); }
    h = h >>> 0;
    const hue1 = h % 360;
    const hue2 = (h >> 3) % 360;
    const el = document.createElement('div');
    el.style.cssText =
      `width:38px;height:38px;border-radius:50%;flex:0 0 auto;` +
      `background:radial-gradient(circle at 32% 28%, hsl(${hue1} 70% 62%), hsl(${hue2} 65% 42%));` +
      `box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.35);`;
    return el;
  }

  const params = new URLSearchParams(window.location.search);
  const dappOrigin = params.get('dapp') ?? '';
  const returnUrl = params.get('return') ?? '';

  const $err = document.getElementById('error-box')!;
  const $list = document.getElementById('accounts-list')!;
  const $none = document.getElementById('no-accounts')!;
  document.getElementById('dapp-origin')!.textContent = dappOrigin || '(unknown)';

  function showError(msg: string) {
    $err.textContent = msg;
    $err.style.display = 'block';
  }

  // Validate the dApp origin and that the return URL is same-origin with it.
  // This is the anti-redirect-abuse guard mirrored from the delegate flow:
  // we only ever hand the address to the origin that asked for it.
  function validatedReturn(): URL | null {
    if (!dappOrigin) { showError('Missing dapp origin parameter.'); return null; }
    let origin: string;
    try { origin = new URL(dappOrigin).origin; } catch { showError('Malformed dapp origin.'); return null; }
    if (returnUrl) {
      let r: URL;
      try { r = new URL(returnUrl); } catch { showError('Malformed return URL.'); return null; }
      if (r.origin !== origin) {
        showError(`Return URL origin (${r.origin}) does not match dapp origin (${origin}).`);
        return null;
      }
      return r;
    }
    // No explicit return URL: that's fine for the popup path (we postMessage
    // to the opener). Synthesize the origin so postResultToOpener targets it.
    return new URL(origin);
  }

  const ret = validatedReturn();

  function finish(search: string) {
    if (!ret) return;
    postResultToOpener(search, ret.origin, returnUrl || undefined);
  }

  document.getElementById('cancel')!.addEventListener('click', () => {
    finish('?g2c_connect=cancelled');
  });

  // Render the device's accounts as pick buttons.
  const accounts = loadAccounts().filter(isContractId);
  if (accounts.length === 0) {
    $none.classList.remove('hidden');
  }
  for (const cAddress of accounts) {
    const name = loadAccountName(cAddress);
    const btn = document.createElement('button');
    btn.className = 'account-row';
    btn.type = 'button';

    btn.appendChild(avatarEl(cAddress));

    const info = document.createElement('div');
    info.className = 'account-info';
    if (name) {
      const n = document.createElement('div');
      n.className = 'account-name';
      n.textContent = name;
      info.appendChild(n);
    }
    const addr = document.createElement('div');
    addr.className = 'account-address';
    addr.textContent = name ? shortAddr(cAddress, 6, 6) : cAddress;
    info.appendChild(addr);
    btn.appendChild(info);

    const chev = document.createElement('span');
    chev.className = 'chev';
    chev.innerHTML =
      '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>';
    btn.appendChild(chev);

    btn.addEventListener('click', () => {
      finish(`?g2c_address=${cAddress}`);
    });
    $list.appendChild(btn);
  }

  if (!ret) {
    // validatedReturn already surfaced the error; disable interaction.
    document.querySelectorAll<HTMLButtonElement>('.account-row').forEach((b) => (b.disabled = true));
  }
</script>
