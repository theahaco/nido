---
// Nido "Warm Nest" layout — sibling to BaseLayout.astro (BaseLayout is left
// untouched). Imports the Nido design system globally so `:root` tokens are
// available everywhere, loads the brand fonts, and renders the prototype shell
// (.stage / .appwrap / .col) around the page <slot/>.
//
// The PR-preview banner and in-app-WebView passkey-warning scripts are ported
// from BaseLayout: the DETECTION LOGIC is byte-for-byte identical; only the
// warning's COPY is reskinned to Nido voice.
import Sidebar from "../components/Sidebar.astro";

interface Props {
  title: string;
  /** Social-card description (og/twitter). Falls back to a generic Nido line. */
  description?: string;
  /** Layout shell. `app` = sidebar+grid on desktop (default); `focused` =
   *  centered card; `bleed` = full-bleed (landing). */
  shell?: "app" | "focused" | "bleed";
}

const {
  title,
  description = "A safe place for everything you own — secured by your passkey on Stellar.",
  shell = "app",
} = Astro.props;

// Absolute URLs for social crawlers (iMessage, Slack, Discord, X, Facebook).
// Crawlers don't run JS and won't resolve relative paths reliably, so these are
// built against `site` (astro.config.mjs). The same generic card serves every
// page/subdomain; per-name cards need an edge function (tracked separately).
const ogImage = new URL("/og-image.png", Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#FFF8F0" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{!title || title.includes('Nido') ? title || 'Nido' : `${title} · Nido`}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Twitter card. Generic, build-time tags so a shared Nido
         link renders a branded preview. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nido" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,800;1,9..144,400;1,9..144,600;1,9..144,800&family=Hanken+Grotesk:wght@400..800&family=JetBrains+Mono:wght@400..600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a id="preview-banner" style="display:none" target="_blank" rel="noopener"></a>
    <div class="stage">
      <div id="webview-warning" style="display:none">
        <p>Passkeys need your real browser to work their magic.</p>
        <p>Tap the menu (<strong>&middot;&middot;&middot;</strong>) and choose <strong>"Open in Safari"</strong> or <strong>"Open in Browser"</strong> — we'll be right here.</p>
      </div>
      <a href="#main-content" class="skip-link">Skip to content</a>
      {shell === "bleed" && <main id="main-content"><slot /></main>}
      {shell === "focused" && (
        <div class="appwrap">
          <main id="main-content" class="col"><slot /></main>
        </div>
      )}
      {shell === "app" && (
        <div class="appwrap appwrap-app">
          <Sidebar />
          <main id="main-content" class="col col-app"><slot /></main>
        </div>
      )}
      {shell !== "focused" && (
        <footer class="site-footer">
          <a href="https://theahaco.github.io/g2c/" target="_blank" rel="noopener">
            Example app ↗
          </a>
        </footer>
      )}
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/nido.css";

  #preview-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: none;
    background: #e11d48;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.5rem 1rem;
    text-align: center;
    text-decoration: none;
    z-index: 9999;
  }

  #preview-banner:hover {
    background: #be123c;
  }

  body:has(#preview-banner[style*="display: block"]) {
    padding-top: 2.2rem;
  }

  #webview-warning {
    background: var(--warn-soft);
    border: 1px solid var(--warn);
    border-radius: var(--r-md);
    color: var(--warn);
    padding: 0.75rem 1rem;
    margin: 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  #webview-warning p {
    margin: 0.25rem 0;
  }

  /* Global link to the live example app (status-message on GitHub Pages). */
  .site-footer {
    text-align: center;
    padding: 1.25rem 1rem 2rem;
    font-size: 0.85rem;
  }
  .site-footer a {
    color: inherit;
    opacity: 0.7;
    text-decoration: none;
  }
  .site-footer a:hover {
    opacity: 1;
    text-decoration: underline;
  }
</style>

<script>
  import { checkPasskeySupport } from "../lib/passkeySupport";

  // Preview banner
  const sub = window.location.hostname.split(".")[0];
  const match = sub.match(/(?:--)?pr-(\d+)$/);
  if (match) {
    const prNum = match[1];
    const banner = document.getElementById("preview-banner") as HTMLAnchorElement;
    banner.textContent = `Preview PR #${prNum}`;
    banner.href = `https://github.com/theahaco/g2c/pull/${prNum}`;
    banner.style.display = "block";
  }

  // Passkey-context warning — two distinct problems get two messages:
  //  · insecure context (http over Tailscale/LAN): the browser disables
  //    passkeys; the fix is the https:// address, NOT "open in Safari".
  //  · in-app WebView (Twitter/Instagram/…): passkeys can't run; open the real
  //    browser. Real Safari/SFSafariViewController include both "Safari" and
  //    "Version/"; WKWebViews omit "Version/".
  const ua = navigator.userAgent;
  const isIOS = /iPhone|iPad|iPod/.test(ua);
  const isInAppBrowser = (isIOS && (!/Safari/.test(ua) || !/Version\//.test(ua)))
    || /Twitter|Instagram|FBAN|FBAV|Line\//.test(ua);

  const support = checkPasskeySupport();
  const warning = document.getElementById("webview-warning")!;

  if (!support.ok && support.reason === "insecure-context") {
    // Replace the in-app copy with the secure-connection message.
    warning.innerHTML =
      "<p>Passkeys need a secure connection to work.</p>" +
      "<p>Open Nido at its <strong>https://</strong> address (or on <strong>localhost</strong>) and you're all set.</p>";
    warning.style.display = "block";
  } else if (isInAppBrowser || !support.ok) {
    // In-app browser, or a secure context that still can't do WebAuthn — the
    // default markup ("open in your browser") is the right advice.
    warning.style.display = "block";
  }
</script>
