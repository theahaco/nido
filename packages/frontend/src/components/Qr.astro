---
// DECORATIVE QR-style graphic — NOT a real, scannable QR code.
//
// This renders a deterministic faux-QR pattern (finder squares + a hashed
// field) purely for visual texture, ported from the prototype's `QR`
// (`app/ui.jsx`). It does NOT encode `data` in any scannable way. ALWAYS pair
// it with a real, copyable address shown beside it — never rely on this being
// scanned.
interface Props {
  /** Seed for the deterministic pattern (e.g. an address). Default "nido". */
  data?: string;
  /** Width & height in px. Default 168. */
  size?: number;
}

const { data = "nido", size = 168 } = Astro.props;

// FNV-1a 32-bit hash (matches the prototype's hashStr).
function hashStr(s: string): number {
  let h = 2166136261;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}

const N = 25;
const cell = size / N;

const isFinder = (r: number, c: number): boolean => {
  const inBox = (br: number, bc: number) =>
    r >= br && r < br + 7 && c >= bc && c < bc + 7;
  return inBox(0, 0) || inBox(0, N - 7) || inBox(N - 7, 0);
};

const finderFill = (r: number, c: number): boolean => {
  const local = (br: number, bc: number) => {
    const rr = r - br;
    const cc = c - bc;
    const ring = rr === 0 || rr === 6 || cc === 0 || cc === 6;
    const core = rr >= 2 && rr <= 4 && cc >= 2 && cc <= 4;
    return ring || core;
  };
  if (r < 7 && c < 7) return local(0, 0);
  if (r < 7 && c >= N - 7) return local(0, N - 7);
  if (r >= N - 7 && c < 7) return local(N - 7, 0);
  return false;
};

interface Cell {
  x: number;
  y: number;
  s: number;
  rx: number;
}
const cells: Cell[] = [];
let h = hashStr(data);
for (let r = 0; r < N; r++) {
  for (let c = 0; c < N; c++) {
    let fill: boolean;
    if (isFinder(r, c)) {
      fill = finderFill(r, c);
    } else {
      h = (Math.imul(h ^ (r * 31 + c), 2654435761)) >>> 0;
      fill = (h & 7) > 3;
    }
    if (fill) {
      cells.push({ x: c * cell, y: r * cell, s: cell + 0.4, rx: cell * 0.18 });
    }
  }
}
---

<svg
  width={size}
  height={size}
  viewBox={`0 0 ${size} ${size}`}
  style="display: block;"
  role="img"
  aria-label="Decorative code"
>
  <rect width={size} height={size} fill="#fffdf8" />
  <g fill="#16140f">
    {cells.map((d) => (
      <rect x={d.x} y={d.y} width={d.s} height={d.s} rx={d.rx} />
    ))}
  </g>
</svg>
