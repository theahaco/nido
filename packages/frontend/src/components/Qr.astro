---
interface Props {
  /** Payload to encode. Can be updated client-side through window.renderNidoQr. */
  data?: string;
  /** Width & height in px. Default 168. */
  size?: number;
  /** Canvas id. */
  id?: string;
}

const { data = "", size = 168, id } = Astro.props;
---

<canvas
  id={id}
  class="nido-qr"
  width={size}
  height={size}
  data-qr-value={data}
  data-qr-size={String(size)}
  style="display: block; width: 100%; height: auto; max-width: 100%;"
  role="img"
  aria-label={data ? "QR code for your Nido address" : "QR code waiting for your Nido address"}
></canvas>

<script>
  import QRCode from "qrcode";

  function renderQr(canvas: HTMLCanvasElement, value: string) {
    const size = Number(canvas.dataset.qrSize || canvas.width || 168);
    if (!value) {
      const ctx = canvas.getContext("2d");
      if (ctx) {
        ctx.fillStyle = "#fffdf8";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
      }
      canvas.setAttribute("aria-label", "QR code waiting for your Nido address");
      return;
    }
    QRCode.toCanvas(canvas, value, {
      width: size,
      margin: 1,
      errorCorrectionLevel: "M",
      color: {
        dark: "#16140f",
        light: "#fffdf8",
      },
    });
    canvas.dataset.qrValue = value;
    canvas.setAttribute("aria-label", "QR code for your Nido address");
  }

  window.renderNidoQr = (target: string | HTMLCanvasElement, value: string) => {
    const canvas =
      typeof target === "string"
        ? document.querySelector<HTMLCanvasElement>(target)
        : target;
    if (canvas) renderQr(canvas, value);
  };

  document.querySelectorAll<HTMLCanvasElement>(".nido-qr").forEach((canvas) => {
    renderQr(canvas, canvas.dataset.qrValue || "");
  });
</script>
