---
// Nido icon set — consistent 24px stroke glyphs.
// Ported from the prototype's `app/icons.jsx` `paths` map.
//   <Icon name="send" size={22} stroke={2} color="currentColor" />
interface Props {
  /** Glyph name; see `paths` keys below. Unknown names render nothing. */
  name: string;
  /** Pixel size (width & height). Default 22. */
  size?: number;
  /** Stroke width. Default 2. */
  stroke?: number;
  /** Stroke color. Default "currentColor". */
  color?: string;
  /** Optional class on the <svg>. */
  class?: string;
}

const { name, size = 22, stroke = 2, color = "currentColor", class: className } =
  Astro.props;

// inner SVG markup keyed by name (verbatim from app/icons.jsx).
