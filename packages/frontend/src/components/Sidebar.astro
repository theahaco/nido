---
// Nido desktop sidebar (≥1024px). Brand mark + wordmark (top), section nav,
// account chip (bottom). Hidden below 1024 via CSS (.nido-sidebar).
import Logo from "./Logo.astro";
import Avatar from "./Avatar.astro";
import Icon from "./Icon.astro";
import MyNidoMenu from "./MyNidoMenu.astro";

const path = Astro.url.pathname;
// "Home" is the account dashboard (/account/) — match it exactly so it isn't
// also highlighted on /account/activity/. Other items match by prefix.
const isActive = (href: string) =>
  href === "/account/" ? path === "/account/" : path.startsWith(href);

const NAV = [
  { href: "/account/", label: "Home", icon: "home" },
  { href: "/transfer/", label: "Send", icon: "send" },
  { href: "/account/activity/", label: "Activity", icon: "activity" },
  { href: "/security/", label: "Security", icon: "shield" },
] as const;
---

<aside class="nido-sidebar">
  <a id="sidebar-home-link" class="nido-sidebar-brand" href="/" data-home-apex aria-label="Nido home">
    <Logo size={20} mark markSize={28} />
  </a>
  <nav class="nido-sidebar-nav">
    {NAV.map((item) => (
      <a
        class:list={["nido-navitem", { "is-active": isActive(item.href) }]}
        href={item.href}
        aria-current={isActive(item.href) ? "page" : undefined}
      >
        <Icon name={item.icon} size={18} />
        <span>{item.label}</span>
      </a>
    ))}
  </nav>
  <MyNidoMenu placement="up">
    <button slot="trigger" type="button" class="nido-sidebar-account" data-mynido-trigger aria-haspopup="true" aria-expanded="false" aria-label="Switch Nido">
      <Avatar seed="nido" size={32} class="js-avatar" />
      <span class="nido-account-name js-account-name">Your Nido</span>
      <span class="mynido-caret" aria-hidden="true" style="margin-left:auto;">▾</span>
    </button>
  </MyNidoMenu>
</aside>

<script>
  import { stripSubdomain } from "@g2c/passkey-sdk";
  // The brand mark is the "exit to the Nido hub" affordance: on an account
  // subdomain "/" redirects back to /account/, so point the brand at the apex
  // home instead (mirrors the mobile #home-link fix). The "Home" nav item is the
  // account dashboard (/account/) and stays account-relative.
  const apexHome = `//${stripSubdomain(window.location.host)}/`;
  document
    .querySelectorAll<HTMLAnchorElement>("[data-home-apex]")
    .forEach((a) => (a.href = apexHome));
</script>
