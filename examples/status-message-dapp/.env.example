# The environment to use: `development`, `testing`, `staging`, `production`.
# `development` builds + deploys the contract to a local network; `testing`
# does the same against Stellar testnet. See environments.toml.
STELLAR_SCAFFOLD_ENV=development

# Location of the config files for this project for the scaffold stellar CLI.
# https://developers.stellar.org/docs/tools/cli/stellar-cli#stellar-config-dir
XDG_CONFIG_HOME=".config"

# soroban-sdk 26 aborts its build script unless this signal is set when the
# contract is built outside `stellar contract build` (scaffold uses raw
# `cargo rustc`). Mirrors the g2c repo justfile.
SOROBAN_SDK_BUILD_SYSTEM_SUPPORTS_SPEC_SHAKING_V2=1

# Prefix with "PUBLIC_" to expose to the frontend.

# Which Stellar network the frontend talks to: LOCAL, TESTNET, FUTURENET, MAINNET.
PUBLIC_STELLAR_NETWORK="LOCAL"
PUBLIC_STELLAR_NETWORK_PASSPHRASE="Standalone Network ; February 2017"
PUBLIC_STELLAR_RPC_URL="http://localhost:8000/rpc"
PUBLIC_STELLAR_HORIZON_URL="http://localhost:8000"

# The g2c deployment apex origin. The g2c wallet module opens this origin's
# /connect/ picker and <account>.<base>/sign/ for the passkey ceremony.
# Use the public deployment for a live demo, or a local g2c instance for dev.
PUBLIC_G2C_BASE="https://nido.fyi"

# --- Testnet (uncomment to point the frontend at testnet) ---
# PUBLIC_STELLAR_NETWORK="TESTNET"
# PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# PUBLIC_STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
# PUBLIC_STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"
